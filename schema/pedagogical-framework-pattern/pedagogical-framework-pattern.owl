@prefix : <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <https://aplo.cs.wright.edu/lod/ontology#> .

<https://aplo.cs.wright.edu/lod/ontology> rdf:type owl:Ontology ;
                                                          dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                                          rdfs:comment "Ontology pattern for representing pedagogical frameworks, ordered pedagogical elements, pedagogical objectives, and pedagogical techniques." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://aplo.cs.wright.edu/lod/ontology#alignedWith
aplo-ont:alignedWith rdf:type owl:ObjectProperty ;
                   owl:inverseOf aplo-ont:isAlignmentFor ;
                   rdf:type owl:AsymmetricProperty ,
                            owl:IrreflexiveProperty ;
                   rdfs:domain aplo-ont:LearningObjective ;
                   rdfs:range aplo-ont:PedagogicalElement ;
                   rdfs:comment "Relates a learning objective to a pedagogical element with which the objective is aligned." ;
                   rdfs:label "alignedWith" .


###  https://aplo.cs.wright.edu/lod/ontology#hasElement
aplo-ont:hasElement rdf:type owl:ObjectProperty ;
                  owl:inverseOf aplo-ont:isElementOf ;
                  rdf:type owl:AsymmetricProperty ,
                           owl:IrreflexiveProperty ;
                  rdfs:domain aplo-ont:PedagogicalFramework ;
                  rdfs:range aplo-ont:PedagogicalElement ;
                  rdfs:comment "Relates a pedagogical framework to an element contained in that framework." ;
                  rdfs:label "hasElement" .


###  https://aplo.cs.wright.edu/lod/ontology#hasNextPedagogicalElement
aplo-ont:hasNextPedagogicalElement rdf:type owl:ObjectProperty ;
                                 owl:inverseOf aplo-ont:hasPreviousPedagogicalElement ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:TransitiveProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:domain aplo-ont:PedagogicalElement ;
                                 rdfs:range aplo-ont:PedagogicalElement ;
                                 rdfs:comment "Relates a pedagogical element to a later element in an ordered framework sequence." ;
                                 rdfs:label "hasNextPedagogicalElement" .


###  https://aplo.cs.wright.edu/lod/ontology#hasPreviousPedagogicalElement
aplo-ont:hasPreviousPedagogicalElement rdf:type owl:ObjectProperty ,
                                              owl:AsymmetricProperty ,
                                              owl:TransitiveProperty ,
                                              owl:IrreflexiveProperty ;
                                     rdfs:domain aplo-ont:PedagogicalElement ;
                                     rdfs:range aplo-ont:PedagogicalElement ;
                                     rdfs:comment "Relates a pedagogical element to an earlier element in an ordered framework sequence." ;
                                     rdfs:label "hasPreviousPedagogicalElement" .


###  https://aplo.cs.wright.edu/lod/ontology#isAlignmentFor
aplo-ont:isAlignmentFor rdf:type owl:ObjectProperty ,
                               owl:AsymmetricProperty ,
                               owl:IrreflexiveProperty ;
                      rdfs:domain aplo-ont:PedagogicalElement ;
                      rdfs:range aplo-ont:LearningObjective ;
                      rdfs:comment "Inverse of alignedWith; relates a pedagogical element to learning objectives aligned with it." ;
                      rdfs:label "isAlignmentFor" .


###  https://aplo.cs.wright.edu/lod/ontology#isElementOf
aplo-ont:isElementOf rdf:type owl:ObjectProperty ,
                            owl:AsymmetricProperty ,
                            owl:IrreflexiveProperty ;
                   rdfs:domain aplo-ont:PedagogicalElement ;
                   rdfs:range aplo-ont:PedagogicalFramework ;
                   rdfs:comment "Inverse of hasElement; relates a pedagogical element to the framework that contains it." ;
                   rdfs:label "isElementOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isLearningObjectiveTargetedBy
aplo-ont:isLearningObjectiveTargetedBy rdf:type owl:ObjectProperty ;
                                     owl:inverseOf aplo-ont:targetsLearningObjective ;
                                     rdf:type owl:AsymmetricProperty ,
                                              owl:IrreflexiveProperty ;
                                     rdfs:domain aplo-ont:LearningObjective ;
                                     rdfs:range aplo-ont:PedagogicalTechnique ;
                                     rdfs:comment "Inverse of targetsLearningObjective; relates a learning objective to pedagogical techniques that target it." ;
                                     rdfs:label "isLearningObjectiveTargetedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isPedagogicalElementSupportedBy
aplo-ont:isPedagogicalElementSupportedBy rdf:type owl:ObjectProperty ;
                                       owl:inverseOf aplo-ont:supportsPedagogicalElement ;
                                       rdf:type owl:AsymmetricProperty ,
                                                owl:IrreflexiveProperty ;
                                       rdfs:domain aplo-ont:PedagogicalElement ;
                                       rdfs:range aplo-ont:PedagogicalTechnique ;
                                       rdfs:comment "Inverse of supportsPedagogicalElement; relates a pedagogical element to techniques that support it." ;
                                       rdfs:label "isPedagogicalElementSupportedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isPedagogicalObjectiveServedBy
aplo-ont:isPedagogicalObjectiveServedBy rdf:type owl:ObjectProperty ;
                                      owl:inverseOf aplo-ont:servesPedagogicalObjective ;
                                      rdf:type owl:AsymmetricProperty ,
                                               owl:IrreflexiveProperty ;
                                      rdfs:domain aplo-ont:PedagogicalObjective ;
                                      rdfs:range aplo-ont:PedagogicalTechnique ;
                                      rdfs:comment "Inverse of servesPedagogicalObjective; relates a pedagogical objective to techniques that serve it." ;
                                      rdfs:label "isPedagogicalObjectiveServedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#servesPedagogicalObjective
aplo-ont:servesPedagogicalObjective rdf:type owl:ObjectProperty ,
                                           owl:AsymmetricProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:domain aplo-ont:PedagogicalTechnique ;
                                  rdfs:range aplo-ont:PedagogicalObjective ;
                                  rdfs:comment "Relates a pedagogical technique to an instructional objective that the technique serves." ;
                                  rdfs:label "servesPedagogicalObjective" .


###  https://aplo.cs.wright.edu/lod/ontology#supportsPedagogicalElement
aplo-ont:supportsPedagogicalElement rdf:type owl:ObjectProperty ,
                                           owl:AsymmetricProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:domain aplo-ont:PedagogicalTechnique ;
                                  rdfs:range aplo-ont:PedagogicalElement ;
                                  rdfs:comment "Relates a pedagogical technique to a pedagogical element that the technique supports." ;
                                  rdfs:label "supportsPedagogicalElement" .


###  https://aplo.cs.wright.edu/lod/ontology#targetsLearningObjective
aplo-ont:targetsLearningObjective rdf:type owl:ObjectProperty ,
                                         owl:AsymmetricProperty ,
                                         owl:IrreflexiveProperty ;
                                rdfs:domain aplo-ont:PedagogicalTechnique ;
                                rdfs:range aplo-ont:LearningObjective ;
                                rdfs:comment "Relates a pedagogical technique to a learning objective targeted by that technique." ;
                                rdfs:label "targetsLearningObjective" .


#################################################################
#    Data properties
#################################################################

###  https://aplo.cs.wright.edu/lod/ontology#hasDescription
aplo-ont:hasDescription rdf:type owl:DatatypeProperty ;
                      rdfs:domain [ rdf:type owl:Class ;
                                    owl:unionOf ( aplo-ont:PedagogicalElement
                                                  aplo-ont:PedagogicalFramework
                                                  aplo-ont:PedagogicalObjective
                                                  aplo-ont:PedagogicalTechnique
                                                )
                                  ] ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Provides an optional textual description for a pedagogical element, framework, objective, or technique." ;
                      rdfs:label "hasDescription" .


###  https://aplo.cs.wright.edu/lod/ontology#hasName
aplo-ont:hasName rdf:type owl:DatatypeProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( aplo-ont:PedagogicalElement
                                           aplo-ont:PedagogicalFramework
                                           aplo-ont:PedagogicalObjective
                                           aplo-ont:PedagogicalTechnique
                                         )
                           ] ;
               rdfs:range xsd:string ;
               rdfs:comment "Provides the required textual name for a pedagogical element, framework, objective, or technique." ;
               rdfs:label "hasName" .


#################################################################
#    Classes
#################################################################

###  https://aplo.cs.wright.edu/lod/ontology#FirstPedagogicalElement
aplo-ont:FirstPedagogicalElement rdf:type owl:Class ;
                               rdfs:subClassOf aplo-ont:PedagogicalElement ;
                               rdfs:comment "Represents the first element in an ordered pedagogical framework sequence." ;
                               rdfs:label "FirstPedagogicalElement" .


###  https://aplo.cs.wright.edu/lod/ontology#LastPedagogicalElement
aplo-ont:LastPedagogicalElement rdf:type owl:Class ;
                              rdfs:subClassOf aplo-ont:PedagogicalElement ;
                              rdfs:comment "Represents the last element in an ordered pedagogical framework sequence." ;
                              rdfs:label "LastPedagogicalElement" .


###  https://aplo.cs.wright.edu/lod/ontology#LearningObjective
aplo-ont:LearningObjective rdf:type owl:Class ;
                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                           owl:onProperty aplo-ont:alignedWith ;
                                           owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                           owl:onClass aplo-ont:PedagogicalElement
                                         ] ;
                         owl:disjointWith aplo-ont:PedagogicalElement ,
                                          aplo-ont:PedagogicalFramework ,
                                          aplo-ont:PedagogicalObjective ,
                                          aplo-ont:PedagogicalTechnique ;
                         rdfs:comment "Represents the ability to capture a target learning outcome." ;
                         rdfs:label "LearningObjective" .


###  https://aplo.cs.wright.edu/lod/ontology#PedagogicalElement
aplo-ont:PedagogicalElement rdf:type owl:Class ;
                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                            owl:onProperty aplo-ont:hasNextPedagogicalElement ;
                                            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                            owl:onClass aplo-ont:PedagogicalElement
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty aplo-ont:hasPreviousPedagogicalElement ;
                                            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                            owl:onClass aplo-ont:PedagogicalElement
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty aplo-ont:isElementOf ;
                                            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                            owl:onClass aplo-ont:PedagogicalFramework
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty aplo-ont:hasName ;
                                            owl:someValuesFrom xsd:string
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty aplo-ont:hasDescription ;
                                            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                            owl:onDataRange xsd:string
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty aplo-ont:hasDescription ;
                                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onDataRange xsd:string
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty aplo-ont:hasName ;
                                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                            owl:onDataRange xsd:string
                                          ] ;
                          owl:disjointWith aplo-ont:PedagogicalFramework ,
                                           aplo-ont:PedagogicalObjective ,
                                           aplo-ont:PedagogicalTechnique ;
                          rdfs:comment "Represents the atomic finite element that is part of a pedagogical framework" ;
                          rdfs:label "PedagogicalElement" .


###  https://aplo.cs.wright.edu/lod/ontology#PedagogicalFramework
aplo-ont:PedagogicalFramework rdf:type owl:Class ;
                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasElement ;
                                              owl:someValuesFrom aplo-ont:PedagogicalElement
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasName ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasDescription ;
                                              owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasDescription ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasName ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ;
                            owl:disjointWith aplo-ont:PedagogicalObjective ,
                                             aplo-ont:PedagogicalTechnique ;
                            rdfs:comment "Represents the ability to capture a pedagogical framework used for instructional design" ;
                            rdfs:label "PedagogicalFramework" .


###  https://aplo.cs.wright.edu/lod/ontology#PedagogicalObjective
aplo-ont:PedagogicalObjective rdf:type owl:Class ;
                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasName ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasDescription ;
                                              owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasDescription ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasName ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ;
                            owl:disjointWith aplo-ont:PedagogicalTechnique ;
                            rdfs:comment "Represents the ability to capture an intended instructional effect or educational purpose that a pedagogical technique is designed to achieve, such as retention, recall, engagement, misconception diagnosis, knowledge transfer, or deeper conceptual understanding." ;
                            rdfs:label "PedagogicalObjective" .


###  https://aplo.cs.wright.edu/lod/ontology#PedagogicalTechnique
aplo-ont:PedagogicalTechnique rdf:type owl:Class ;
                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:servesPedagogicalObjective ;
                                              owl:someValuesFrom aplo-ont:PedagogicalObjective
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:supportsPedagogicalElement ;
                                              owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                              owl:onClass aplo-ont:PedagogicalElement
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:targetsLearningObjective ;
                                              owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                              owl:onClass aplo-ont:LearningObjective
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasName ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasDescription ;
                                              owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasDescription ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty aplo-ont:hasName ;
                                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                              owl:onDataRange xsd:string
                                            ] ;
                            rdfs:comment "Represents the ability to capture a specific instructional method that is used in instructional design" ;
                            rdfs:label "PedagogicalTechnique" .


