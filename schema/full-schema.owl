#################################################################
#    General axioms
#################################################################

[ rdf:type owl:Restriction ;
  owl:onProperty pf-ont:assessesLearningFeedback ;
  owl:someValuesFrom pf-ont:LearningFeedback ;
  rdfs:subClassOf pf-ont:EvaluationTechnique
] .


[ rdf:type owl:Restriction ;
  owl:onProperty pf-ont:assessesLearningObjective ;
  owl:someValuesFrom pf-ont:LearningObjective ;
  rdfs:subClassOf pf-ont:EvaluationTechnique
] .


[ rdf:type owl:Restriction ;
  owl:onProperty pf-ont:evaluatesTopicAwarenessOf ;
  owl:someValuesFrom edu-ont:Topic ;
  rdfs:subClassOf pf-ont:EvaluationAssessmentExercise
] .


[ rdf:type owl:Restriction ;
  owl:onProperty pf-ont:hasEvaluationTechniqueType ;
  owl:someValuesFrom pf-ont:EvaluationTechniqueType ;
  rdfs:subClassOf pf-ont:EvaluationTechnique
] .


[ rdf:type owl:Restriction ;
  owl:onProperty pf-ont:provideFeedback ;
  owl:someValuesFrom pf-ont:Response ;
  rdfs:subClassOf pf-ont:EvaluationTechnique
] .


