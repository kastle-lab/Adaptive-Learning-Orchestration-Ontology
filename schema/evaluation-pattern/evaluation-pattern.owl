@prefix : <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@base <https://aplo.cs.wright.edu/lod/ontology#> .

<https://aplo.cs.wright.edu/lod/ontology> rdf:type owl:Ontology ;
                                                          dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                                          rdfs:comment "Ontology pattern for representing evaluation activities, assessment exercises, evaluation metrics, feedback, responses, and related provenance." .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://aplo.cs.wright.edu/lod/ontology#affectsAwarenessObservation
aplo-ont:affectsAwarenessObservation rdf:type owl:ObjectProperty ;
                                   owl:inverseOf aplo-ont:isAwarenessObservationAffectedBy ;
                                   rdf:type owl:AsymmetricProperty ,
                                            owl:IrreflexiveProperty ;
                                   rdfs:domain aplo-ont:Response ;
                                   rdfs:range aplo-ont:AwarenessObservation ;
                                   rdfs:comment "Relates a response or evaluation result to an awareness observation that the response influences or updates." ;
                                   rdfs:label "affectsAwarenessObservation" .


###  https://aplo.cs.wright.edu/lod/ontology#affectsStrategy
aplo-ont:affectsStrategy rdf:type owl:ObjectProperty ;
                       owl:inverseOf aplo-ont:isStrategyAffectedBy ;
                       rdf:type owl:AsymmetricProperty ,
                                owl:IrreflexiveProperty ;
                       rdfs:domain aplo-ont:LearningFeedback ;
                       rdfs:range aplo-ont:LearningStrategy ;
                       rdfs:comment "Relates learning feedback to a learning strategy that the feedback may influence." ;
                       rdfs:label "affectsStrategy" .


###  https://aplo.cs.wright.edu/lod/ontology#assessesLearningFeedback
aplo-ont:assessesLearningFeedback rdf:type owl:ObjectProperty ;
                                owl:inverseOf aplo-ont:isLearningFeedbackAssessedBy ;
                                rdf:type owl:AsymmetricProperty ,
                                         owl:IrreflexiveProperty ;
                                rdfs:domain aplo-ont:EvaluationTechnique ;
                                rdfs:range aplo-ont:LearningFeedback ;
                                rdfs:comment "Relates an evaluation technique to learning feedback that the technique assesses." ;
                                rdfs:label "assessesLearningFeedback" .


###  https://aplo.cs.wright.edu/lod/ontology#assessesLearningObjective
aplo-ont:assessesLearningObjective rdf:type owl:ObjectProperty ;
                                 owl:inverseOf aplo-ont:isLearningObjectiveAssessedBy ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:domain aplo-ont:EvaluationTechnique ;
                                 rdfs:range aplo-ont:LearningObjective ;
                                 rdfs:comment "Relates an evaluation technique to a learning objective that the technique assesses." ;
                                 rdfs:label "assessesLearningObjective" .


###  https://aplo.cs.wright.edu/lod/ontology#evaluatesTopicAwarenessOf
aplo-ont:evaluatesTopicAwarenessOf rdf:type owl:ObjectProperty ;
                                 owl:inverseOf aplo-ont:isTopicAwarenessEvaluatedBy ;
                                 rdf:type owl:AsymmetricProperty ,
                                          owl:IrreflexiveProperty ;
                                 rdfs:domain aplo-ont:EvaluationAssessmentExercise ;
                                 rdfs:range edu-ont:Topic ;
                                 rdfs:comment "Relates an assessment exercise to the topic whose learner awareness is being evaluated." ;
                                 rdfs:label "evaluatesTopicAwarenessOf" .


###  https://aplo.cs.wright.edu/lod/ontology#hasAssessmentExercise
aplo-ont:hasAssessmentExercise rdf:type owl:ObjectProperty ;
                             owl:inverseOf aplo-ont:isAssessmentExerciseOf ;
                             rdf:type owl:AsymmetricProperty ,
                                      owl:IrreflexiveProperty ;
                             rdfs:domain [ rdf:type owl:Class ;
                                           owl:unionOf ( edu-ont:Media
                                                         edu-ont:Module
                                                       )
                                         ] ;
                             rdfs:range aplo-ont:EvaluationAssessmentExercise ;
                             rdfs:comment "Relates a module or media resource to an assessment exercise included in or associated with that learning resource." ;
                             rdfs:label "hasAssessmentExercise" .


###  https://aplo.cs.wright.edu/lod/ontology#hasEvaluationMetric
aplo-ont:hasEvaluationMetric rdf:type owl:ObjectProperty ;
                           owl:inverseOf aplo-ont:isEvaluationMetricOf ;
                           rdf:type owl:AsymmetricProperty ,
                                    owl:IrreflexiveProperty ;
                           rdfs:domain aplo-ont:EvaluationTechnique ;
                           rdfs:range aplo-ont:EvaluationMetric ;
                           rdfs:comment "Relates an evaluation technique to the metric used to measure or report its result." ;
                           rdfs:label "hasEvaluationMetric" .


###  https://aplo.cs.wright.edu/lod/ontology#hasEvaluationTechniqueType
aplo-ont:hasEvaluationTechniqueType rdf:type owl:ObjectProperty ;
                                  owl:inverseOf aplo-ont:isEvaluationTechniqueTypeOf ;
                                  rdf:type owl:AsymmetricProperty ,
                                           owl:IrreflexiveProperty ;
                                  rdfs:domain aplo-ont:EvaluationTechnique ;
                                  rdfs:range aplo-ont:EvaluationTechniqueType ;
                                  rdfs:comment "Relates an evaluation technique to a controlled type or category for that technique." ;
                                  rdfs:label "hasEvaluationTechniqueType" .


###  https://aplo.cs.wright.edu/lod/ontology#hasLearningFeedbackType
aplo-ont:hasLearningFeedbackType rdf:type owl:ObjectProperty ;
                               owl:inverseOf aplo-ont:isLearningFeedbackTypeOf ;
                               rdf:type owl:AsymmetricProperty ,
                                        owl:IrreflexiveProperty ;
                               rdfs:domain aplo-ont:LearningFeedback ;
                               rdfs:range aplo-ont:LearningFeedbackType ;
                               rdfs:comment "Relates learning feedback to a controlled feedback type or category." ;
                               rdfs:label "hasLearningFeedbackType" .


###  https://aplo.cs.wright.edu/lod/ontology#hasResponseTime
aplo-ont:hasResponseTime rdf:type owl:ObjectProperty ;
                       owl:inverseOf aplo-ont:isResponseTimeOf ;
                       rdf:type owl:AsymmetricProperty ,
                                owl:IrreflexiveProperty ;
                       rdfs:domain aplo-ont:Response ;
                       rdfs:range aplo-ont:TemporalExtent ;
                       rdfs:comment "Relates a response or evaluation result to the time or duration associated with that response." ;
                       rdfs:label "hasResponseTime" .


###  https://aplo.cs.wright.edu/lod/ontology#hasSource
aplo-ont:hasSource rdf:type owl:ObjectProperty ;
                 owl:inverseOf aplo-ont:isSourceOf ;
                 rdf:type owl:AsymmetricProperty ,
                          owl:IrreflexiveProperty ;
                 rdfs:domain aplo-ont:Response ;
                 rdfs:range aplo-ont:Source ;
                 rdfs:comment "Relates a response to the source or agentive origin that produced it." ;
                 rdfs:label "hasSource" .


###  https://aplo.cs.wright.edu/lod/ontology#hasUnit
aplo-ont:hasUnit rdf:type owl:ObjectProperty ;
               owl:inverseOf aplo-ont:isUnitOf ;
               rdf:type owl:AsymmetricProperty ,
                        owl:IrreflexiveProperty ;
               rdfs:domain aplo-ont:EvaluationResult ;
               rdfs:range aplo-ont:EvaluationMetric ;
               rdfs:comment "Relates an evaluation result to the metric or unit in which the result is expressed." ;
               rdfs:label "hasUnit" .


###  https://aplo.cs.wright.edu/lod/ontology#hasWorkloadLevel
aplo-ont:hasWorkloadLevel rdf:type owl:ObjectProperty ;
                        owl:inverseOf aplo-ont:isWorkloadLevelOf ;
                        rdf:type owl:AsymmetricProperty ,
                                 owl:IrreflexiveProperty ;
                        rdfs:domain aplo-ont:EvaluationAssessmentExercise ;
                        rdfs:range aplo-ont:WorkloadLevel ;
                        rdfs:comment "Relates an assessment exercise to the controlled workload level assigned to it." ;
                        rdfs:label "hasWorkloadLevel" .


###  https://aplo.cs.wright.edu/lod/ontology#isAssessmentExerciseOf
aplo-ont:isAssessmentExerciseOf rdf:type owl:ObjectProperty ,
                                       owl:AsymmetricProperty ,
                                       owl:IrreflexiveProperty ;
                              rdfs:domain aplo-ont:EvaluationAssessmentExercise ;
                              rdfs:range [ rdf:type owl:Class ;
                                           owl:unionOf ( edu-ont:Media
                                                         edu-ont:Module
                                                       )
                                         ] ;
                              rdfs:comment "Inverse of hasAssessmentExercise; relates an assessment exercise back to the media or module that includes it." ;
                              rdfs:label "isAssessmentExerciseOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isAwarenessObservationAffectedBy
aplo-ont:isAwarenessObservationAffectedBy rdf:type owl:ObjectProperty ,
                                                 owl:AsymmetricProperty ,
                                                 owl:IrreflexiveProperty ;
                                        rdfs:domain aplo-ont:AwarenessObservation ;
                                        rdfs:range aplo-ont:Response ;
                                        rdfs:comment "Inverse of affectsAwarenessObservation; relates an awareness observation to the response that influences it." ;
                                        rdfs:label "isAwarenessObservationAffectedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isEvaluationMetricOf
aplo-ont:isEvaluationMetricOf rdf:type owl:ObjectProperty ,
                                     owl:AsymmetricProperty ,
                                     owl:IrreflexiveProperty ;
                            rdfs:domain aplo-ont:EvaluationMetric ;
                            rdfs:range aplo-ont:EvaluationTechnique ;
                            rdfs:comment "Inverse of hasEvaluationMetric; relates an evaluation metric to the technique that uses it." ;
                            rdfs:label "isEvaluationMetricOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isEvaluationTechniqueTypeOf
aplo-ont:isEvaluationTechniqueTypeOf rdf:type owl:ObjectProperty ,
                                            owl:AsymmetricProperty ,
                                            owl:IrreflexiveProperty ;
                                   rdfs:domain aplo-ont:EvaluationTechniqueType ;
                                   rdfs:range aplo-ont:EvaluationTechnique ;
                                   rdfs:comment "Inverse of hasEvaluationTechniqueType; relates a technique type to evaluation techniques classified by it." ;
                                   rdfs:label "isEvaluationTechniqueTypeOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isFeedbackProvidedBy
aplo-ont:isFeedbackProvidedBy rdf:type owl:ObjectProperty ;
                            owl:inverseOf aplo-ont:provideFeedback ;
                            rdf:type owl:AsymmetricProperty ,
                                     owl:IrreflexiveProperty ;
                            rdfs:domain aplo-ont:Response ;
                            rdfs:range aplo-ont:EvaluationTechnique ;
                            rdfs:comment "Inverse of provideFeedback; relates a response or feedback artifact to the evaluation technique that produced it." ;
                            rdfs:label "isFeedbackProvidedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isLearningFeedbackAssessedBy
aplo-ont:isLearningFeedbackAssessedBy rdf:type owl:ObjectProperty ,
                                             owl:AsymmetricProperty ,
                                             owl:IrreflexiveProperty ;
                                    rdfs:domain aplo-ont:LearningFeedback ;
                                    rdfs:range aplo-ont:EvaluationTechnique ;
                                    rdfs:comment "Inverse of assessesLearningFeedback; relates learning feedback to an evaluation technique that assesses it." ;
                                    rdfs:label "isLearningFeedbackAssessedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isLearningFeedbackTypeOf
aplo-ont:isLearningFeedbackTypeOf rdf:type owl:ObjectProperty ,
                                         owl:AsymmetricProperty ,
                                         owl:IrreflexiveProperty ;
                                rdfs:domain aplo-ont:LearningFeedbackType ;
                                rdfs:range aplo-ont:LearningFeedback ;
                                rdfs:comment "Inverse of hasLearningFeedbackType; relates a feedback type to feedback instances classified by it." ;
                                rdfs:label "isLearningFeedbackTypeOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isLearningObjectiveAssessedBy
aplo-ont:isLearningObjectiveAssessedBy rdf:type owl:ObjectProperty ,
                                              owl:AsymmetricProperty ,
                                              owl:IrreflexiveProperty ;
                                     rdfs:domain aplo-ont:LearningObjective ;
                                     rdfs:range aplo-ont:EvaluationTechnique ;
                                     rdfs:comment "Inverse of assessesLearningObjective; relates a learning objective to an evaluation technique that assesses it." ;
                                     rdfs:label "isLearningObjectiveAssessedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isResponseTimeOf
aplo-ont:isResponseTimeOf rdf:type owl:ObjectProperty ,
                                 owl:AsymmetricProperty ,
                                 owl:IrreflexiveProperty ;
                        rdfs:domain aplo-ont:TemporalExtent ;
                        rdfs:range aplo-ont:Response ;
                        rdfs:comment "Inverse of hasResponseTime; relates a temporal extent to the response timed by it." ;
                        rdfs:label "isResponseTimeOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isSourceOf
aplo-ont:isSourceOf rdf:type owl:ObjectProperty ,
                           owl:AsymmetricProperty ,
                           owl:IrreflexiveProperty ;
                  rdfs:domain aplo-ont:Source ;
                  rdfs:range aplo-ont:Response ;
                  rdfs:comment "Inverse of hasSource; relates a source to a response produced by that source." ;
                  rdfs:label "isSourceOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isStrategyAffectedBy
aplo-ont:isStrategyAffectedBy rdf:type owl:ObjectProperty ,
                                     owl:AsymmetricProperty ,
                                     owl:IrreflexiveProperty ;
                            rdfs:domain aplo-ont:LearningStrategy ;
                            rdfs:range aplo-ont:LearningFeedback ;
                            rdfs:comment "Inverse of affectsStrategy; relates a learning strategy to feedback that may influence it." ;
                            rdfs:label "isStrategyAffectedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isTechniqueUsedBy
aplo-ont:isTechniqueUsedBy rdf:type owl:ObjectProperty ;
                         owl:inverseOf aplo-ont:usesTechnique ;
                         rdf:type owl:AsymmetricProperty ,
                                  owl:IrreflexiveProperty ;
                         rdfs:domain aplo-ont:EvaluationTechnique ;
                         rdfs:range aplo-ont:EvaluationAssessmentExercise ;
                         rdfs:comment "Inverse of usesTechnique; relates an evaluation technique to an assessment exercise that uses it." ;
                         rdfs:label "isTechniqueUsedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isTopicAwarenessEvaluatedBy
aplo-ont:isTopicAwarenessEvaluatedBy rdf:type owl:ObjectProperty ,
                                            owl:AsymmetricProperty ,
                                            owl:IrreflexiveProperty ;
                                   rdfs:domain edu-ont:Topic ;
                                   rdfs:range aplo-ont:EvaluationAssessmentExercise ;
                                   rdfs:comment "Inverse of evaluatesTopicAwarenessOf; relates a topic to an assessment exercise evaluating awareness of it." ;
                                   rdfs:label "isTopicAwarenessEvaluatedBy" .


###  https://aplo.cs.wright.edu/lod/ontology#isUnitOf
aplo-ont:isUnitOf rdf:type owl:ObjectProperty ,
                         owl:AsymmetricProperty ,
                         owl:IrreflexiveProperty ;
                rdfs:domain aplo-ont:EvaluationMetric ;
                rdfs:range aplo-ont:EvaluationResult ;
                rdfs:comment "Inverse of hasUnit; relates an evaluation metric to an evaluation result expressed with that metric." ;
                rdfs:label "isUnitOf" .


###  https://aplo.cs.wright.edu/lod/ontology#isWorkloadLevelOf
aplo-ont:isWorkloadLevelOf rdf:type owl:ObjectProperty ,
                                  owl:AsymmetricProperty ,
                                  owl:IrreflexiveProperty ;
                         rdfs:domain aplo-ont:WorkloadLevel ;
                         rdfs:range aplo-ont:EvaluationAssessmentExercise ;
                         rdfs:comment "Inverse of hasWorkloadLevel; relates a workload level to an assessment exercise assigned that level." ;
                         rdfs:label "isWorkloadLevelOf" .


###  https://aplo.cs.wright.edu/lod/ontology#provideFeedback
aplo-ont:provideFeedback rdf:type owl:ObjectProperty ,
                                owl:AsymmetricProperty ,
                                owl:IrreflexiveProperty ;
                       rdfs:domain aplo-ont:EvaluationTechnique ;
                       rdfs:range aplo-ont:Response ;
                       rdfs:comment "Relates an evaluation technique to a response or feedback artifact produced by that technique." ;
                       rdfs:label "provideFeedback" .


###  https://aplo.cs.wright.edu/lod/ontology#usesTechnique
aplo-ont:usesTechnique rdf:type owl:ObjectProperty ,
                              owl:AsymmetricProperty ,
                              owl:IrreflexiveProperty ;
                     rdfs:domain aplo-ont:EvaluationAssessmentExercise ;
                     rdfs:range aplo-ont:EvaluationTechnique ;
                     rdfs:comment "Relates an assessment exercise to the evaluation technique used by that exercise." ;
                     rdfs:label "usesTechnique" .


#################################################################
#    Data properties
#################################################################

###  https://aplo.cs.wright.edu/lod/ontology#asString
aplo-ont:asString rdf:type owl:DatatypeProperty ;
                rdfs:domain aplo-ont:EvaluationMetric ;
                rdfs:range rdfs:Literal ;
                rdfs:comment "Provides a literal string representation for an evaluation metric." ;
                rdfs:label "asString" .


###  https://aplo.cs.wright.edu/lod/ontology#hasValue
aplo-ont:hasValue rdf:type owl:DatatypeProperty ;
                rdfs:domain aplo-ont:EvaluationResult ;
                rdfs:range rdfs:Literal ;
                rdfs:comment "Provides the literal value recorded for an evaluation result." ;
                rdfs:label "hasValue" .


#################################################################
#    Classes
#################################################################

###  https://edugate.cs.wright.edu/lod/ontology#Media
edu-ont:Media rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty aplo-ont:hasAssessmentExercise ;
                                owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                owl:onClass aplo-ont:EvaluationAssessmentExercise
                              ] ;
              rdfs:comment "Represents a learning media resource that may include or be associated with assessment exercises." ;
              rdfs:label "Media" .


###  https://edugate.cs.wright.edu/lod/ontology#Module
edu-ont:Module rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty aplo-ont:hasAssessmentExercise ;
                                 owl:someValuesFrom aplo-ont:EvaluationAssessmentExercise
                               ] ;
               rdfs:comment "Represents an instructional module that includes one or more assessment exercises." ;
               rdfs:label "Module" .


###  https://edugate.cs.wright.edu/lod/ontology#Topic
edu-ont:Topic rdf:type owl:Class ;
              owl:disjointWith aplo-ont:Agent ,
                               aplo-ont:EvaluationAssessmentExercise ,
                               aplo-ont:Response ;
              rdfs:comment "Represents a subject matter topic that can be evaluated for learner awareness or understanding." ;
              rdfs:label "Topic" .


###  https://aplo.cs.wright.edu/lod/ontology#Agent
aplo-ont:Agent rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty aplo-ont:isSourceOf ;
                               owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                               owl:onClass aplo-ont:Response
                             ] ;
             owl:disjointWith aplo-ont:EvaluationAssessmentExercise ,
                              aplo-ont:EvaluationMetric ,
                              aplo-ont:Response ,
                              aplo-ont:TemporalExtent ;
             rdfs:comment "Represents an actor or agentive entity, such as a person, system, or service, that can originate a response." ;
             rdfs:label "Agent" .


###  https://aplo.cs.wright.edu/lod/ontology#AwarenessObservation
aplo-ont:AwarenessObservation rdf:type owl:Class ;
                            rdfs:comment "Represents an observation or assessment event that estimates a learner's awareness of a topic or skill." ;
                            rdfs:label "AwarenessObservation" .


###  https://aplo.cs.wright.edu/lod/ontology#EvaluationAssessmentExercise
aplo-ont:EvaluationAssessmentExercise rdf:type owl:Class ;
                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                      owl:onProperty aplo-ont:evaluatesTopicAwarenessOf ;
                                                      owl:someValuesFrom edu-ont:Topic
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty aplo-ont:hasWorkloadLevel ;
                                                      owl:someValuesFrom aplo-ont:WorkloadLevel
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty aplo-ont:usesTechnique ;
                                                      owl:someValuesFrom aplo-ont:EvaluationTechnique
                                                    ] ,
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty aplo-ont:hasWorkloadLevel ;
                                                      owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                      owl:onClass aplo-ont:WorkloadLevel
                                                    ] ;
                                    rdfs:comment "Represents an assessment activity or exercise through which a learner's understanding, awareness, or performance is evaluated with respect to a topic, skill, or learning objective." ;
                                    rdfs:label "EvaluationAssessmentExercise" .


###  https://aplo.cs.wright.edu/lod/ontology#EvaluationMetric
aplo-ont:EvaluationMetric rdf:type owl:Class ;
                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                          owl:onProperty aplo-ont:asString ;
                                          owl:someValuesFrom rdfs:Literal
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty aplo-ont:asString ;
                                          owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                        ] ;
                        rdfs:comment "Represents the ability to capture what type of measurable unit of evaluation techniques was utilized." ;
                        rdfs:label "EvaluationMetric" .


###  https://aplo.cs.wright.edu/lod/ontology#EvaluationResult
aplo-ont:EvaluationResult rdf:type owl:Class ;
                        rdfs:subClassOf aplo-ont:Response ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty aplo-ont:hasUnit ;
                                          owl:someValuesFrom aplo-ont:EvaluationMetric
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty aplo-ont:hasValue ;
                                          owl:someValuesFrom rdfs:Literal
                                        ] ;
                        rdfs:comment "Represents the ability to capture what measurable value of evaluation technique was utilized." ;
                        rdfs:label "EvaluationResult" .


###  https://aplo.cs.wright.edu/lod/ontology#EvaluationTechnique
aplo-ont:EvaluationTechnique rdf:type owl:Class ;
                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                             owl:onProperty aplo-ont:hasEvaluationMetric ;
                                             owl:someValuesFrom aplo-ont:EvaluationMetric
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty aplo-ont:hasEvaluationTechniqueType ;
                                             owl:someValuesFrom aplo-ont:EvaluationTechniqueType
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty aplo-ont:assessesLearningFeedback ;
                                             owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                             owl:onClass aplo-ont:LearningFeedback
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty aplo-ont:assessesLearningObjective ;
                                             owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                             owl:onClass aplo-ont:LearningObjective
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty aplo-ont:provideFeedback ;
                                             owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                             owl:onClass aplo-ont:Response
                                           ] ;
                           rdfs:comment "Represents the ability to capture what evaluation methods are utilized for assessment." ;
                           rdfs:label "EvaluationTechnique" .


###  https://aplo.cs.wright.edu/lod/ontology#EvaluationTechniqueType
aplo-ont:EvaluationTechniqueType rdf:type owl:Class ;
                               rdfs:comment "Represents the ability to capture categories of evaluation techniques, like \"summative/formative\", \"automated\", etc. These are controlled vocabulary classifications." ;
                               rdfs:label "EvaluationTechniqueType" .


###  https://aplo.cs.wright.edu/lod/ontology#LearningFeedback
aplo-ont:LearningFeedback rdf:type owl:Class ;
                        rdfs:subClassOf aplo-ont:Response ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty aplo-ont:hasLearningFeedbackType ;
                                          owl:someValuesFrom aplo-ont:LearningFeedbackType
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty aplo-ont:affectsStrategy ;
                                          owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                          owl:onClass aplo-ont:LearningStrategy
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty aplo-ont:hasLearningFeedbackType ;
                                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                          owl:onClass aplo-ont:LearningFeedbackType
                                        ] ;
                        rdfs:comment "Represents the ability to capture an observation about a learner's performance or understanding." ;
                        rdfs:label "LearningFeedback" .


###  https://aplo.cs.wright.edu/lod/ontology#LearningFeedbackType
aplo-ont:LearningFeedbackType rdf:type owl:Class ;
                            rdfs:comment "Represents the ability to capture categories of feedback like \"corrective feedback\", \"motivational feedback\", etc. These are controlled vocabulary classifications." ;
                            rdfs:label "LearningFeedbackType" .


###  https://aplo.cs.wright.edu/lod/ontology#LearningObjective
aplo-ont:LearningObjective rdf:type owl:Class ;
                         rdfs:comment "Represents the ability to capture a target learning outcome." ;
                         rdfs:label "LearningObjective" .


###  https://aplo.cs.wright.edu/lod/ontology#LearningStrategy
aplo-ont:LearningStrategy rdf:type owl:Class ;
                        rdfs:comment "Represents the ability to capture how instructional components come together in a teaching plan." ;
                        rdfs:label "LearningStrategy" .


###  https://aplo.cs.wright.edu/lod/ontology#Response
aplo-ont:Response rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty aplo-ont:hasSource ;
                                  owl:someValuesFrom aplo-ont:Source
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty aplo-ont:affectsAwarenessObservation ;
                                  owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                  owl:onClass aplo-ont:AwarenessObservation
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty aplo-ont:hasResponseTime ;
                                  owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
                                  owl:onClass aplo-ont:TemporalExtent
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty aplo-ont:hasResponseTime ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass aplo-ont:TemporalExtent
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty aplo-ont:hasSource ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass aplo-ont:Source
                                ] ;
                rdfs:comment "Represents the ability to capture an explicit feedback message or system output delivered to a learner." ;
                rdfs:label "Response" .


###  https://aplo.cs.wright.edu/lod/ontology#Source
aplo-ont:Source rdf:type owl:Class ;
              rdfs:subClassOf aplo-ont:Agent ;
              rdfs:comment "Represents the ability to capture an entity (teacher, LLM) that produced a Response." ;
              rdfs:label "Source" .


###  https://aplo.cs.wright.edu/lod/ontology#TemporalExtent
aplo-ont:TemporalExtent rdf:type owl:Class ;
                      rdfs:comment "Represents a time point, interval, or duration associated with a response or evaluation event." ;
                      rdfs:label "TemporalExtent" .


###  https://aplo.cs.wright.edu/lod/ontology#WorkloadLevel
aplo-ont:WorkloadLevel rdf:type owl:Class ;
                     rdfs:comment "Represents a controlled vocabulary level that models the estimated effort, time commitment, or assessment burden associated." ;
                     rdfs:label "WorkloadLevel" .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:Restriction ;
  owl:onProperty aplo-ont:assessesLearningFeedback ;
  owl:someValuesFrom aplo-ont:LearningFeedback ;
  rdfs:subClassOf aplo-ont:EvaluationTechnique
] .


[ rdf:type owl:Restriction ;
  owl:onProperty aplo-ont:assessesLearningObjective ;
  owl:someValuesFrom aplo-ont:LearningObjective ;
  rdfs:subClassOf aplo-ont:EvaluationTechnique
] .


[ rdf:type owl:Restriction ;
  owl:onProperty aplo-ont:evaluatesTopicAwarenessOf ;
  owl:someValuesFrom edu-ont:Topic ;
  rdfs:subClassOf aplo-ont:EvaluationAssessmentExercise
] .


[ rdf:type owl:Restriction ;
  owl:onProperty aplo-ont:hasEvaluationTechniqueType ;
  owl:someValuesFrom aplo-ont:EvaluationTechniqueType ;
  rdfs:subClassOf aplo-ont:EvaluationTechnique
] .


[ rdf:type owl:Restriction ;
  owl:onProperty aplo-ont:provideFeedback ;
  owl:someValuesFrom aplo-ont:Response ;
  rdfs:subClassOf aplo-ont:EvaluationTechnique
] .


