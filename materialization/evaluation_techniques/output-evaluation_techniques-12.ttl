@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechnique.Auto%20Scored%20Concept%20Check a aplo-ont:EvaluationTechnique ;
    rdf:value "Auto Scored Concept Check"^^xsd:string ;
    aplo-ont:assessesLearningFeedback aplo-r:learningFeedback.Learner%20Darwin.Learning%20Platform.Knowledge%20Graph%20Structure%20Explanation%20Coaching%20Note ;
    aplo-ont:assessesLearningObjective aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Describe%20knowledge%20graph%20structure ;
    aplo-ont:hasEvaluationMetric aplo-r:evaluationMetric.Correctness%20Flag,
        aplo-r:evaluationMetric.Score%20Percent ;
    aplo-ont:hasEvaluationTechniqueType aplo-r:evaluationTechniqueType.Automated,
        aplo-r:evaluationTechniqueType.Formative,
        aplo-r:evaluationTechniqueType.Low%20Stakes ;
    aplo-ont:provideFeedback aplo-r:response.Learner%20Darwin.Adaptive%20Tutor.Knowledge%20Graph%20Structure%20Explanation%20Next%20Step .

aplo-r:evaluationMetric.Correctness%20Flag a aplo-ont:EvaluationMetric ;
    rdf:value "Correctness Flag"^^xsd:string .

aplo-r:evaluationMetric.Score%20Percent a aplo-ont:EvaluationMetric ;
    rdf:value "Score Percent"^^xsd:string .

aplo-r:evaluationTechniqueType.Automated a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Automated"^^xsd:string .

aplo-r:evaluationTechniqueType.Formative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Formative"^^xsd:string .

aplo-r:evaluationTechniqueType.Low%20Stakes a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Low Stakes"^^xsd:string .

aplo-r:learningFeedback.Learner%20Darwin.Learning%20Platform.Knowledge%20Graph%20Structure%20Explanation%20Coaching%20Note a aplo-ont:LearningFeedback ;
    rdf:value "Knowledge Graph Structure Explanation Coaching Note"^^xsd:string .

aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Describe%20knowledge%20graph%20structure a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Describe knowledge graph structure"^^xsd:string .

aplo-r:response.Learner%20Darwin.Adaptive%20Tutor.Knowledge%20Graph%20Structure%20Explanation%20Next%20Step a aplo-ont:Response ;
    rdf:value "Knowledge Graph Structure Explanation Next Step"^^xsd:string .

