@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechnique.Ontology%20Modeling%20Review a aplo-ont:EvaluationTechnique ;
    rdf:value "Ontology Modeling Review"^^xsd:string ;
    aplo-ont:assessesLearningFeedback aplo-r:learningFeedback.Learner%20Darwin.Instructor%20Reviewer.Description%20Logic%20Constraint%20Reasoning%20Correction%20Note ;
    aplo-ont:assessesLearningObjective aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Analyze%20description%20logic%20constraints ;
    aplo-ont:hasEvaluationMetric aplo-r:evaluationMetric.Confidence%20Rating,
        aplo-r:evaluationMetric.Rubric%20Level ;
    aplo-ont:hasEvaluationTechniqueType aplo-r:evaluationTechniqueType.Instructor%20Reviewed,
        aplo-r:evaluationTechniqueType.Modeling%20Artifact,
        aplo-r:evaluationTechniqueType.Summative ;
    aplo-ont:provideFeedback aplo-r:response.Learner%20Darwin.Adaptive%20Tutor.Description%20Logic%20Constraint%20Reasoning%20Hint .

aplo-r:evaluationMetric.Confidence%20Rating a aplo-ont:EvaluationMetric ;
    rdf:value "Confidence Rating"^^xsd:string .

aplo-r:evaluationMetric.Rubric%20Level a aplo-ont:EvaluationMetric ;
    rdf:value "Rubric Level"^^xsd:string .

aplo-r:evaluationTechniqueType.Instructor%20Reviewed a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Instructor Reviewed"^^xsd:string .

aplo-r:evaluationTechniqueType.Modeling%20Artifact a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Modeling Artifact"^^xsd:string .

aplo-r:evaluationTechniqueType.Summative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Summative"^^xsd:string .

aplo-r:learningFeedback.Learner%20Darwin.Instructor%20Reviewer.Description%20Logic%20Constraint%20Reasoning%20Correction%20Note a aplo-ont:LearningFeedback ;
    rdf:value "Description Logic Constraint Reasoning Correction Note"^^xsd:string .

aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Analyze%20description%20logic%20constraints a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Analyze description logic constraints"^^xsd:string .

aplo-r:response.Learner%20Darwin.Adaptive%20Tutor.Description%20Logic%20Constraint%20Reasoning%20Hint a aplo-ont:Response ;
    rdf:value "Description Logic Constraint Reasoning Hint"^^xsd:string .

