@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechnique.Short%20Explanation%20Rubric a aplo-ont:EvaluationTechnique ;
    rdf:value "Short Explanation Rubric"^^xsd:string ;
    aplo-ont:assessesLearningFeedback aplo-r:learningFeedback.Learner%20Ella.Instructor%20Reviewer.Nanopublication%20Claim%20Modeling%20Revision%20Guidance ;
    aplo-ont:assessesLearningObjective aplo-r:learningObjective.Executive%20KG%20Outcome%20Framing.Model%20nanopublication%20claims ;
    aplo-ont:hasEvaluationMetric aplo-r:evaluationMetric.Confidence%20Rating,
        aplo-r:evaluationMetric.Rubric%20Level,
        aplo-r:evaluationMetric.Score%20Percent ;
    aplo-ont:hasEvaluationTechniqueType aplo-r:evaluationTechniqueType.Explanation%20Based,
        aplo-r:evaluationTechniqueType.Formative,
        aplo-r:evaluationTechniqueType.Instructor%20Reviewed ;
    aplo-ont:provideFeedback aplo-r:response.Learner%20Ella.Adaptive%20Tutor.Nanopublication%20Claim%20Modeling%20Review%20Guidance .

aplo-r:evaluationMetric.Confidence%20Rating a aplo-ont:EvaluationMetric ;
    rdf:value "Confidence Rating"^^xsd:string .

aplo-r:evaluationMetric.Rubric%20Level a aplo-ont:EvaluationMetric ;
    rdf:value "Rubric Level"^^xsd:string .

aplo-r:evaluationMetric.Score%20Percent a aplo-ont:EvaluationMetric ;
    rdf:value "Score Percent"^^xsd:string .

aplo-r:evaluationTechniqueType.Explanation%20Based a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Explanation Based"^^xsd:string .

aplo-r:evaluationTechniqueType.Formative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Formative"^^xsd:string .

aplo-r:evaluationTechniqueType.Instructor%20Reviewed a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Instructor Reviewed"^^xsd:string .

aplo-r:learningFeedback.Learner%20Ella.Instructor%20Reviewer.Nanopublication%20Claim%20Modeling%20Revision%20Guidance a aplo-ont:LearningFeedback ;
    rdf:value "Nanopublication Claim Modeling Revision Guidance"^^xsd:string .

aplo-r:learningObjective.Executive%20KG%20Outcome%20Framing.Model%20nanopublication%20claims a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Model nanopublication claims"^^xsd:string .

aplo-r:response.Learner%20Ella.Adaptive%20Tutor.Nanopublication%20Claim%20Modeling%20Review%20Guidance a aplo-ont:Response ;
    rdf:value "Nanopublication Claim Modeling Review Guidance"^^xsd:string .

