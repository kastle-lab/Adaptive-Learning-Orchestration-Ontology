@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechnique.Auto%20Scored%20Concept%20Check a aplo-ont:EvaluationTechnique ;
    rdf:value "Auto Scored Concept Check"^^xsd:string ;
    aplo-ont:assessesLearningFeedback aplo-r:learningFeedback.Learner%20Ronnie.Learning%20Platform.RDFS%20Vocabulary%20Reasoning%20Evidence%20Prompt ;
    aplo-ont:assessesLearningObjective aplo-r:learningObjective.KG%20Resource%20Development%20Practice.Apply%20RDFS%20vocabulary%20reasoning ;
    aplo-ont:hasEvaluationMetric aplo-r:evaluationMetric.Correctness%20Flag,
        aplo-r:evaluationMetric.Score%20Percent ;
    aplo-ont:hasEvaluationTechniqueType aplo-r:evaluationTechniqueType.Automated,
        aplo-r:evaluationTechniqueType.Formative,
        aplo-r:evaluationTechniqueType.Low%20Stakes ;
    aplo-ont:provideFeedback aplo-r:response.Learner%20Ronnie.Adaptive%20Tutor.RDFS%20Vocabulary%20Inference%20Reviewpoint%20Advice .

aplo-r:evaluationMetric.Correctness%20Flag a aplo-ont:EvaluationMetric ;
    rdf:value "Correctness Flag"^^xsd:string .

aplo-r:evaluationMetric.Score%20Percent a aplo-ont:EvaluationMetric ;
    rdf:value "Score Percent"^^xsd:string .

aplo-r:evaluationTechniqueType.Automated a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Automated"^^xsd:string .

aplo-r:evaluationTechniqueType.Formative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Formative"^^xsd:string .

aplo-r:evaluationTechniqueType.Low%20Stakes a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Low Stakes"^^xsd:string .

aplo-r:learningFeedback.Learner%20Ronnie.Learning%20Platform.RDFS%20Vocabulary%20Reasoning%20Evidence%20Prompt a aplo-ont:LearningFeedback ;
    rdf:value "RDFS Vocabulary Reasoning Evidence Prompt"^^xsd:string .

aplo-r:learningObjective.KG%20Resource%20Development%20Practice.Apply%20RDFS%20vocabulary%20reasoning a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Apply RDFS vocabulary reasoning"^^xsd:string .

aplo-r:response.Learner%20Ronnie.Adaptive%20Tutor.RDFS%20Vocabulary%20Inference%20Reviewpoint%20Advice a aplo-ont:Response ;
    rdf:value "RDFS Vocabulary Inference Reviewpoint Advice"^^xsd:string .

