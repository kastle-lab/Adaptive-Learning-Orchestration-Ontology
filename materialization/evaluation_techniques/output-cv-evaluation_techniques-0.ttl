@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechniqueType.Automated a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Automated"^^xsd:string .

aplo-r:evaluationTechniqueType.Explanation%20Based a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Explanation Based"^^xsd:string .

aplo-r:evaluationTechniqueType.Formative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Formative"^^xsd:string .

aplo-r:evaluationTechniqueType.Instructor%20Reviewed a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Instructor Reviewed"^^xsd:string .

aplo-r:evaluationTechniqueType.Low%20Stakes a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Low Stakes"^^xsd:string .

aplo-r:evaluationTechniqueType.Modeling%20Artifact a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Modeling Artifact"^^xsd:string .

aplo-r:evaluationTechniqueType.Summative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Summative"^^xsd:string .

