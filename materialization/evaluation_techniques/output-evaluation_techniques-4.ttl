@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechnique.Triple%20Interpretation%20Quiz a aplo-ont:EvaluationTechnique ;
    rdf:value "Triple Interpretation Quiz"^^xsd:string ;
    aplo-ont:assessesLearningFeedback aplo-r:learningFeedback.Learner%20Blair.Learning%20Platform.Corrective%20Feedback%20on%20Triple%20Components ;
    aplo-ont:assessesLearningObjective aplo-r:learningObjective.RDF%20Practice%20Session.Interpret%20RDF%20triple%20components ;
    aplo-ont:hasEvaluationMetric aplo-r:evaluationMetric.Correctness%20Flag,
        aplo-r:evaluationMetric.Score%20Percent ;
    aplo-ont:hasEvaluationTechniqueType aplo-r:evaluationTechniqueType.Automated,
        aplo-r:evaluationTechniqueType.Formative ;
    aplo-ont:provideFeedback aplo-r:response.Learner%20Blair.Learning%20Platform.Triple%20Component%20Hint%20Response .

aplo-r:evaluationMetric.Correctness%20Flag a aplo-ont:EvaluationMetric ;
    rdf:value "Correctness Flag"^^xsd:string .

aplo-r:evaluationMetric.Score%20Percent a aplo-ont:EvaluationMetric ;
    rdf:value "Score Percent"^^xsd:string .

aplo-r:evaluationTechniqueType.Automated a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Automated"^^xsd:string .

aplo-r:evaluationTechniqueType.Formative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Formative"^^xsd:string .

aplo-r:learningFeedback.Learner%20Blair.Learning%20Platform.Corrective%20Feedback%20on%20Triple%20Components a aplo-ont:LearningFeedback ;
    rdf:value "Corrective Feedback on Triple Components"^^xsd:string .

aplo-r:learningObjective.RDF%20Practice%20Session.Interpret%20RDF%20triple%20components a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Interpret RDF triple components"^^xsd:string .

aplo-r:response.Learner%20Blair.Learning%20Platform.Triple%20Component%20Hint%20Response a aplo-ont:Response ;
    rdf:value "Triple Component Hint Response"^^xsd:string .

