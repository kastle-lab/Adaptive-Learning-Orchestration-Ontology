@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechnique.Ontology%20Modeling%20Review a aplo-ont:EvaluationTechnique ;
    rdf:value "Ontology Modeling Review"^^xsd:string ;
    aplo-ont:assessesLearningFeedback aplo-r:learningFeedback.Learner%20Stella.Instructor%20Reviewer.Upper%20Ontology%20Alignment%20Review%20Comment ;
    aplo-ont:assessesLearningObjective aplo-r:learningObjective.Secure%20KG%20Implementation%20Training.Align%20models%20with%20upper%20ontology%20concepts ;
    aplo-ont:hasEvaluationMetric aplo-r:evaluationMetric.Confidence%20Rating,
        aplo-r:evaluationMetric.Rubric%20Level ;
    aplo-ont:hasEvaluationTechniqueType aplo-r:evaluationTechniqueType.Instructor%20Reviewed,
        aplo-r:evaluationTechniqueType.Modeling%20Artifact,
        aplo-r:evaluationTechniqueType.Summative ;
    aplo-ont:provideFeedback aplo-r:response.Learner%20Stella.Adaptive%20Tutor.Upper%20Ontology%20Alignment%20Revision%20Cue .

aplo-r:evaluationMetric.Confidence%20Rating a aplo-ont:EvaluationMetric ;
    rdf:value "Confidence Rating"^^xsd:string .

aplo-r:evaluationMetric.Rubric%20Level a aplo-ont:EvaluationMetric ;
    rdf:value "Rubric Level"^^xsd:string .

aplo-r:evaluationTechniqueType.Instructor%20Reviewed a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Instructor Reviewed"^^xsd:string .

aplo-r:evaluationTechniqueType.Modeling%20Artifact a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Modeling Artifact"^^xsd:string .

aplo-r:evaluationTechniqueType.Summative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Summative"^^xsd:string .

aplo-r:learningFeedback.Learner%20Stella.Instructor%20Reviewer.Upper%20Ontology%20Alignment%20Review%20Comment a aplo-ont:LearningFeedback ;
    rdf:value "Upper Ontology Alignment Review Comment"^^xsd:string .

aplo-r:learningObjective.Secure%20KG%20Implementation%20Training.Align%20models%20with%20upper%20ontology%20concepts a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Align models with upper ontology concepts"^^xsd:string .

aplo-r:response.Learner%20Stella.Adaptive%20Tutor.Upper%20Ontology%20Alignment%20Revision%20Cue a aplo-ont:Response ;
    rdf:value "Upper Ontology Alignment Revision Cue"^^xsd:string .

