@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationTechnique.Ontology%20Modeling%20Review a aplo-ont:EvaluationTechnique ;
    rdf:value "Ontology Modeling Review"^^xsd:string ;
    aplo-ont:assessesLearningFeedback aplo-r:learningFeedback.Learner%20Casey.Instructor%20Reviewer.Strategic%20Feedback%20on%20OWL%20Modeling ;
    aplo-ont:assessesLearningObjective aplo-r:learningObjective.OWL%20Modeling%20Practice.Analyze%20OWL%20axioms%20in%20a%20modeling%20scenario,
        aplo-r:learningObjective.OWL%20Modeling%20Practice.Differentiate%20OWL%20data%20and%20object%20properties,
        aplo-r:learningObjective.OWL%20Modeling%20Practice.Revise%20an%20ontology%20model%20after%20feedback ;
    aplo-ont:hasEvaluationMetric aplo-r:evaluationMetric.Confidence%20Rating,
        aplo-r:evaluationMetric.Rubric%20Level ;
    aplo-ont:hasEvaluationTechniqueType aplo-r:evaluationTechniqueType.Instructor%20Reviewed,
        aplo-r:evaluationTechniqueType.Modeling%20Artifact,
        aplo-r:evaluationTechniqueType.Summative ;
    aplo-ont:provideFeedback aplo-r:response.Learner%20Casey.Instructor%20Reviewer.OWL%20Modeling%20Response .

aplo-r:evaluationMetric.Confidence%20Rating a aplo-ont:EvaluationMetric ;
    rdf:value "Confidence Rating"^^xsd:string .

aplo-r:evaluationMetric.Rubric%20Level a aplo-ont:EvaluationMetric ;
    rdf:value "Rubric Level"^^xsd:string .

aplo-r:evaluationTechniqueType.Instructor%20Reviewed a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Instructor Reviewed"^^xsd:string .

aplo-r:evaluationTechniqueType.Modeling%20Artifact a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Modeling Artifact"^^xsd:string .

aplo-r:evaluationTechniqueType.Summative a aplo-ont:EvaluationTechniqueType ;
    rdf:value "Summative"^^xsd:string .

aplo-r:learningFeedback.Learner%20Casey.Instructor%20Reviewer.Strategic%20Feedback%20on%20OWL%20Modeling a aplo-ont:LearningFeedback ;
    rdf:value "Strategic Feedback on OWL Modeling"^^xsd:string .

aplo-r:learningObjective.OWL%20Modeling%20Practice.Analyze%20OWL%20axioms%20in%20a%20modeling%20scenario a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Analyze OWL axioms in a modeling scenario"^^xsd:string .

aplo-r:learningObjective.OWL%20Modeling%20Practice.Differentiate%20OWL%20data%20and%20object%20properties a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Differentiate OWL data and object properties"^^xsd:string .

aplo-r:learningObjective.OWL%20Modeling%20Practice.Revise%20an%20ontology%20model%20after%20feedback a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Revise an ontology model after feedback"^^xsd:string .

aplo-r:response.Learner%20Casey.Instructor%20Reviewer.OWL%20Modeling%20Response a aplo-ont:Response ;
    rdf:value "OWL Modeling Response"^^xsd:string .

