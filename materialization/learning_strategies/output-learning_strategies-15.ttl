@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningStrategy.Collaborative%20KG%20Delivery%20Planning.Collaborative%20KG%20Implementation%20Strategy a aplo-ont:LearningStrategy ;
    aplo-ont:hasDescription "Distribute expertise across identifiers and provenance work then synthesize annotated evidence into a shared delivery plan."^^xsd:string ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Identify%20identifier%20patterns,
        aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Model%20provenance%20relationships%20with%20PROV-O ;
    aplo-ont:hasName "Collaborative KG Implementation Strategy"^^xsd:string ;
    aplo-ont:hasPedagogicalTechnique aplo-r:pedagogicalTechnique.Collaborative%20Annotation,
        aplo-r:pedagogicalTechnique.Group%20Synthesis,
        aplo-r:pedagogicalTechnique.Jigsaw%20Activity,
        aplo-r:pedagogicalTechnique.Peer%20Review%20Protocol .

aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Identify%20identifier%20patterns a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Identify identifier patterns"^^xsd:string .

aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Model%20provenance%20relationships%20with%20PROV-O a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Model provenance relationships with PROV-O"^^xsd:string .

aplo-r:pedagogicalTechnique.Collaborative%20Annotation a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Collaborative Annotation"^^xsd:string .

aplo-r:pedagogicalTechnique.Group%20Synthesis a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Group Synthesis"^^xsd:string .

aplo-r:pedagogicalTechnique.Jigsaw%20Activity a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Jigsaw Activity"^^xsd:string .

aplo-r:pedagogicalTechnique.Peer%20Review%20Protocol a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Peer Review Protocol"^^xsd:string .

