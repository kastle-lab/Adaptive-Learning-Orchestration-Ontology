@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningStrategy.Developer%20Knowledge%20Graph%20Implementation%20Practice.Developer%20KG%20Implementation%20Strategy a aplo-ont:LearningStrategy ;
    aplo-ont:hasDescription "Use expert modeling faded examples and implementation error analysis so developer practice stays close to deployable KG decisions."^^xsd:string ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Construct%20SPARQL%20query%20patterns,
        aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Explain%20ontology%20components,
        aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Select%20entailment%20regimes ;
    aplo-ont:hasName "Developer KG Implementation Strategy"^^xsd:string ;
    aplo-ont:hasPedagogicalTechnique aplo-r:pedagogicalTechnique.Error%20Analysis,
        aplo-r:pedagogicalTechnique.Faded%20Worked%20Example,
        aplo-r:pedagogicalTechnique.Progress%20Monitoring%20Checklist,
        aplo-r:pedagogicalTechnique.Think%20Aloud%20Modeling .

aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Construct%20SPARQL%20query%20patterns a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Construct SPARQL query patterns"^^xsd:string .

aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Explain%20ontology%20components a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Explain ontology components"^^xsd:string .

aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Select%20entailment%20regimes a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Select entailment regimes"^^xsd:string .

aplo-r:pedagogicalTechnique.Error%20Analysis a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Error Analysis"^^xsd:string .

aplo-r:pedagogicalTechnique.Faded%20Worked%20Example a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Faded Worked Example"^^xsd:string .

aplo-r:pedagogicalTechnique.Progress%20Monitoring%20Checklist a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Progress Monitoring Checklist"^^xsd:string .

aplo-r:pedagogicalTechnique.Think%20Aloud%20Modeling a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Think Aloud Modeling"^^xsd:string .

