@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningStrategy.Executive%20KG%20Value%20Review.Executive%20KG%20Value%20Strategy a aplo-ont:LearningStrategy ;
    aplo-ont:hasDescription "Frame technical ideas through realistic cases relevance cues and product-style review for executive decision support."^^xsd:string ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Executive%20KG%20Value%20Review.Explain%20RDF%20Plus%20property%20reasoning,
        aplo-r:learningObjective.Executive%20KG%20Value%20Review.Interpret%20predicate%20logic%20statements,
        aplo-r:learningObjective.Executive%20KG%20Value%20Review.Map%20Dublin%20Core%20metadata%20fields ;
    aplo-ont:hasName "Executive KG Value Strategy"^^xsd:string ;
    aplo-ont:hasPedagogicalTechnique aplo-r:pedagogicalTechnique.Case%20Based%20Scenario,
        aplo-r:pedagogicalTechnique.Public%20Product%20Review,
        aplo-r:pedagogicalTechnique.Reflective%20Debrief,
        aplo-r:pedagogicalTechnique.Relevance%20Framing .

aplo-r:learningObjective.Executive%20KG%20Value%20Review.Explain%20RDF%20Plus%20property%20reasoning a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Explain RDF Plus property reasoning"^^xsd:string .

aplo-r:learningObjective.Executive%20KG%20Value%20Review.Interpret%20predicate%20logic%20statements a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Interpret predicate logic statements"^^xsd:string .

aplo-r:learningObjective.Executive%20KG%20Value%20Review.Map%20Dublin%20Core%20metadata%20fields a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Map Dublin Core metadata fields"^^xsd:string .

aplo-r:pedagogicalTechnique.Case%20Based%20Scenario a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Case Based Scenario"^^xsd:string .

aplo-r:pedagogicalTechnique.Public%20Product%20Review a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Public Product Review"^^xsd:string .

aplo-r:pedagogicalTechnique.Reflective%20Debrief a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Reflective Debrief"^^xsd:string .

aplo-r:pedagogicalTechnique.Relevance%20Framing a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Relevance Framing"^^xsd:string .

