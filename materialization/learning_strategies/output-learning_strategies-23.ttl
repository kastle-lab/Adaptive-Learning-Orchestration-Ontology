@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningStrategy.KG%20Research%20Representation%20Study.KG%20Research%20Comparison%20Strategy a aplo-ont:LearningStrategy ;
    aplo-ont:hasDescription "Structure research comparison through debate collaborative annotation analogical comparison and explicit self explanation."^^xsd:string ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.KG%20Research%20Representation%20Study.Analyze%20OWL%20modeling%20constraints,
        aplo-r:learningObjective.KG%20Research%20Representation%20Study.Compare%20property%20graph%20representations ;
    aplo-ont:hasName "KG Research Comparison Strategy"^^xsd:string ;
    aplo-ont:hasPedagogicalTechnique aplo-r:pedagogicalTechnique.Analogical%20Comparison,
        aplo-r:pedagogicalTechnique.Collaborative%20Annotation,
        aplo-r:pedagogicalTechnique.Debate%20Protocol,
        aplo-r:pedagogicalTechnique.Self%20Explanation .

aplo-r:learningObjective.KG%20Research%20Representation%20Study.Analyze%20OWL%20modeling%20constraints a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Analyze OWL modeling constraints"^^xsd:string .

aplo-r:learningObjective.KG%20Research%20Representation%20Study.Compare%20property%20graph%20representations a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Compare property graph representations"^^xsd:string .

aplo-r:pedagogicalTechnique.Analogical%20Comparison a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Analogical Comparison"^^xsd:string .

aplo-r:pedagogicalTechnique.Collaborative%20Annotation a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Collaborative Annotation"^^xsd:string .

aplo-r:pedagogicalTechnique.Debate%20Protocol a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Debate Protocol"^^xsd:string .

aplo-r:pedagogicalTechnique.Self%20Explanation a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasName "Self Explanation"^^xsd:string .

