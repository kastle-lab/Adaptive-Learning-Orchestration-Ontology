aplo-r:response.Learner%20Blair.Learning%20Platform.SPARQL%20Query%20Practice%20Score a aplo-ont:Response ;
    rdf:value "SPARQL Query Practice Score"^^xsd:string,
        "Score percent 82 for SPARQL query practice"^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Blair.Query.SPARQL%20Query%20Construction.SPARQL%20Awareness%20After%20Practice ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Blair.Learning%20Platform.SPARQL%20Query%20Practice%20Score.2026-01-19T13%3A22%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Learning%20Platform .

aplo-r:awarenessObservation.Learner%20Blair.Query.SPARQL%20Query%20Construction.SPARQL%20Awareness%20After%20Practice a aplo-ont:AwarenessObservation ;
    rdf:value "SPARQL Awareness After Practice"^^xsd:string .

aplo-r:source.Learning%20Platform a aplo-ont:Source ;
    rdf:value "Learning Platform"^^xsd:string .

aplo-r:temporalExtent.Learner%20Blair.Learning%20Platform.SPARQL%20Query%20Practice%20Score.2026-01-19T13%3A22%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-01-19T13:22:00+00:00"^^xsd:dateTime .

