aplo-r:response.Learner%20Courtney.Learning%20Platform.Datalog%20Rule%20Trace%20Task%20Score a aplo-ont:Response ;
    rdf:value "Datalog Rule Trace Task Score"^^xsd:string,
        "Datalog Rule Trace performance trace: 73 Score Percent for Datalog Rule Interpretation."^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Courtney.Inference.Datalog%20Rule%20Interpretation.Datalog%20Rule%20Interpretation%20Rubric%20Update ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Courtney.Learning%20Platform.Datalog%20Rule%20Trace%20Task%20Score.2026-02-07T14%3A07%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Learning%20Platform .

aplo-r:awarenessObservation.Learner%20Courtney.Inference.Datalog%20Rule%20Interpretation.Datalog%20Rule%20Interpretation%20Rubric%20Update a aplo-ont:AwarenessObservation ;
    rdf:value "Datalog Rule Interpretation Rubric Update"^^xsd:string .

aplo-r:source.Learning%20Platform a aplo-ont:Source ;
    rdf:value "Learning Platform"^^xsd:string .

aplo-r:temporalExtent.Learner%20Courtney.Learning%20Platform.Datalog%20Rule%20Trace%20Task%20Score.2026-02-07T14%3A07%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-02-07T14:07:00+00:00"^^xsd:dateTime .

