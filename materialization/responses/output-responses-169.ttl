@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:response.Learner%20Riley.Adaptive%20Tutor.Semantic%20Web%20Foundation%20Baseline%20Hint a aplo-ont:Response ;
    rdf:value "Semantic Web Foundation Baseline Hint"^^xsd:string,
        "Semantic Web Vocabulary Recall: distinguish metadata examples from knowledge graph structure examples before repeating the concept check."^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Riley.Metadata.Semantic%20Web%20Vocabulary%20Recall.Semantic%20Web%20Foundation%20Baseline%20Awareness ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Riley.Adaptive%20Tutor.Semantic%20Web%20Foundation%20Baseline%20Hint.2026-03-22T14%3A00%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Adaptive%20Tutor .

aplo-r:awarenessObservation.Learner%20Riley.Metadata.Semantic%20Web%20Vocabulary%20Recall.Semantic%20Web%20Foundation%20Baseline%20Awareness a aplo-ont:AwarenessObservation ;
    rdf:value "Semantic Web Foundation Baseline Awareness"^^xsd:string .

aplo-r:source.Adaptive%20Tutor a aplo-ont:Source ;
    rdf:value "Adaptive Tutor"^^xsd:string .

aplo-r:temporalExtent.Learner%20Riley.Adaptive%20Tutor.Semantic%20Web%20Foundation%20Baseline%20Hint.2026-03-22T14%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-03-22T14:00:00+00:00"^^xsd:dateTime .

