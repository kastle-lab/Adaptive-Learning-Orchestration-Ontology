@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:response.Learner%20Blair.Learning%20Platform.Corrective%20Feedback%20on%20Identifier%20Patterns a aplo-ont:Response ;
    rdf:value "Corrective Feedback on Identifier Patterns"^^xsd:string,
        "Identifier patterns were confused with general labels; review URI namespace hash and slash examples"^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Blair.URI.Linked%20Data%20Identifier%20Recognition.Identifier%20Awareness%20After%20Check ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Blair.Learning%20Platform.Corrective%20Feedback%20on%20Identifier%20Patterns.2026-01-15T10%3A09%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Learning%20Platform .

aplo-r:awarenessObservation.Learner%20Blair.URI.Linked%20Data%20Identifier%20Recognition.Identifier%20Awareness%20After%20Check a aplo-ont:AwarenessObservation ;
    rdf:value "Identifier Awareness After Check"^^xsd:string .

aplo-r:source.Learning%20Platform a aplo-ont:Source ;
    rdf:value "Learning Platform"^^xsd:string .

aplo-r:temporalExtent.Learner%20Blair.Learning%20Platform.Corrective%20Feedback%20on%20Identifier%20Patterns.2026-01-15T10%3A09%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-01-15T10:09:00+00:00"^^xsd:dateTime .

