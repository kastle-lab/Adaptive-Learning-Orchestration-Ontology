@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:response.Learner%20Alex.Instructor%20Reviewer.Ontology%20Explanation%20Response a aplo-ont:Response ;
    rdf:value "Ontology Explanation Response"^^xsd:string,
        "Your explanation identifies classes and properties; revise it to mention axioms and shared semantics"^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Alex.Ontology.Ontology%20Concept%20Explanation.Ontology%20Awareness%20After%20Review ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Alex.Instructor%20Reviewer.Ontology%20Explanation%20Response.2026-01-16T14%3A30%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Instructor%20Reviewer .

aplo-r:awarenessObservation.Learner%20Alex.Ontology.Ontology%20Concept%20Explanation.Ontology%20Awareness%20After%20Review a aplo-ont:AwarenessObservation ;
    rdf:value "Ontology Awareness After Review"^^xsd:string .

aplo-r:source.Instructor%20Reviewer a aplo-ont:Source ;
    rdf:value "Instructor Reviewer"^^xsd:string .

aplo-r:temporalExtent.Learner%20Alex.Instructor%20Reviewer.Ontology%20Explanation%20Response.2026-01-16T14%3A30%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-01-16T14:30:00+00:00"^^xsd:dateTime .

