aplo-r:response.Learner%20Silas.Adaptive%20Tutor.Semantic%20Web%20History%20Explanation%20Extension%20Prompt a aplo-ont:Response ;
    rdf:value "Semantic Web History Explanation Extension Prompt"^^xsd:string,
        "Semantic Web History Explanation: write the relation or rule in plain language using the Ontology evidence from Semantic Web Timeline Explanation."^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Silas.Ontology.Semantic%20Web%20History%20Explanation.Semantic%20Web%20History%20Explanation%20Application%20Snapshot ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Silas.Adaptive%20Tutor.Semantic%20Web%20History%20Explanation%20Extension%20Prompt.2026-03-12T14%3A28%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Adaptive%20Tutor .

aplo-r:awarenessObservation.Learner%20Silas.Ontology.Semantic%20Web%20History%20Explanation.Semantic%20Web%20History%20Explanation%20Application%20Snapshot a aplo-ont:AwarenessObservation ;
    rdf:value "Semantic Web History Explanation Application Snapshot"^^xsd:string .

aplo-r:source.Adaptive%20Tutor a aplo-ont:Source ;
    rdf:value "Adaptive Tutor"^^xsd:string .

aplo-r:temporalExtent.Learner%20Silas.Adaptive%20Tutor.Semantic%20Web%20History%20Explanation%20Extension%20Prompt.2026-03-12T14%3A28%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-03-12T14:28:00+00:00"^^xsd:dateTime .

