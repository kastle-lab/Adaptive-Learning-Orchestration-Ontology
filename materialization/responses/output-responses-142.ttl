@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:response.Learner%20Kai.Adaptive%20Tutor.Property%20Graph%20Comparison%20Hint a aplo-ont:Response ;
    rdf:value "Property Graph Comparison Hint"^^xsd:string,
        "Property Graph Comparison: try the task again with one fewer hint using the Graph evidence from Property Graph Comparison Brief."^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Kai.Graph.Property%20Graph%20Comparison.Property%20Graph%20Comparison%20Checkpoint ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Kai.Adaptive%20Tutor.Property%20Graph%20Comparison%20Hint.2026-03-13T14%3A00%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Adaptive%20Tutor .

aplo-r:awarenessObservation.Learner%20Kai.Graph.Property%20Graph%20Comparison.Property%20Graph%20Comparison%20Checkpoint a aplo-ont:AwarenessObservation ;
    rdf:value "Property Graph Comparison Checkpoint"^^xsd:string .

aplo-r:source.Adaptive%20Tutor a aplo-ont:Source ;
    rdf:value "Adaptive Tutor"^^xsd:string .

aplo-r:temporalExtent.Learner%20Kai.Adaptive%20Tutor.Property%20Graph%20Comparison%20Hint.2026-03-13T14%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-03-13T14:00:00+00:00"^^xsd:dateTime .

