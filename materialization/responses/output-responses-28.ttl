    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Darwin.Adaptive%20Tutor.Knowledge%20Graph%20Structure%20Explanation%20Next%20Step.2026-02-03T14%3A14%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Adaptive%20Tutor .

aplo-r:awarenessObservation.Learner%20Darwin.Schema.Knowledge%20Graph%20Structure%20Explanation.Knowledge%20Graph%20Structure%20Explanation%20Practice%20Update a aplo-ont:AwarenessObservation ;
