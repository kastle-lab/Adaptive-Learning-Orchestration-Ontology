aplo-r:response.Learner%20Darwin.Adaptive%20Tutor.Knowledge%20Graph%20Structure%20Explanation%20Next%20Step a aplo-ont:Response ;
    rdf:value "Knowledge Graph Structure Explanation Next Step"^^xsd:string,
