aplo-r:response.Learner%20Darwin.Adaptive%20Tutor.Description%20Logic%20Constraint%20Reasoning%20Hint a aplo-ont:Response ;
    rdf:value "Description Logic Constraint Reasoning Hint"^^xsd:string,
        "Description Logic Constraint Reasoning: add a short rationale for the chosen representation using the Expressivity evidence from Description Logic Constraint Review."^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Darwin.Expressivity.Description%20Logic%20Constraint%20Reasoning.Description%20Logic%20Constraint%20Reasoning%20Checkpoint ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Darwin.Adaptive%20Tutor.Description%20Logic%20Constraint%20Reasoning%20Hint.2026-02-09T14%3A21%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Adaptive%20Tutor .

aplo-r:awarenessObservation.Learner%20Darwin.Expressivity.Description%20Logic%20Constraint%20Reasoning.Description%20Logic%20Constraint%20Reasoning%20Checkpoint a aplo-ont:AwarenessObservation ;
    rdf:value "Description Logic Constraint Reasoning Checkpoint"^^xsd:string .

aplo-r:source.Adaptive%20Tutor a aplo-ont:Source ;
    rdf:value "Adaptive Tutor"^^xsd:string .

aplo-r:temporalExtent.Learner%20Darwin.Adaptive%20Tutor.Description%20Logic%20Constraint%20Reasoning%20Hint.2026-02-09T14%3A21%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-02-09T14:21:00+00:00"^^xsd:dateTime .

