@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:response.Learner%20Connie.Adaptive%20Tutor.Propositional%20Statement%20Reasoning%20Tutor%20Note a aplo-ont:Response ;
    rdf:value "Propositional Statement Reasoning Tutor Note"^^xsd:string,
        "Propositional Statement Reasoning: check whether the example supports the conclusion using the Conjunction evidence from Proposition Truth Table Task."^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Connie.Conjunction.Propositional%20Statement%20Reasoning.Propositional%20Statement%20Reasoning%20Revision%20State ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Connie.Adaptive%20Tutor.Propositional%20Statement%20Reasoning%20Tutor%20Note.2026-02-06T14%3A00%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Adaptive%20Tutor .

aplo-r:awarenessObservation.Learner%20Connie.Conjunction.Propositional%20Statement%20Reasoning.Propositional%20Statement%20Reasoning%20Revision%20State a aplo-ont:AwarenessObservation ;
    rdf:value "Propositional Statement Reasoning Revision State"^^xsd:string .

aplo-r:source.Adaptive%20Tutor a aplo-ont:Source ;
    rdf:value "Adaptive Tutor"^^xsd:string .

aplo-r:temporalExtent.Learner%20Connie.Adaptive%20Tutor.Propositional%20Statement%20Reasoning%20Tutor%20Note.2026-02-06T14%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-02-06T14:00:00+00:00"^^xsd:dateTime .

