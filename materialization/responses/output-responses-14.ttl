@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:response.Learner%20Alex.Learning%20Platform.Metadata%20Concept%20Check%20Score a aplo-ont:Response ;
    rdf:value "Metadata Concept Check Score"^^xsd:string,
        "Metadata Concept Check scored result: 82 Score Percent for Semantic Web Vocabulary Recall with correct examples and one missed boundary case."^^xsd:string ;
    aplo-ont:affectsAwarenessObservation aplo-r:awarenessObservation.Learner%20Alex.Metadata.Semantic%20Web%20Vocabulary%20Recall.Metadata%20Awareness%20After%20Check ;
    aplo-ont:hasResponseTime aplo-r:temporalExtent.Learner%20Alex.Learning%20Platform.Metadata%20Concept%20Check%20Score.2026-01-15T09%3A45%3A00Z ;
    aplo-ont:hasSource aplo-r:source.Learning%20Platform .

aplo-r:awarenessObservation.Learner%20Alex.Metadata.Semantic%20Web%20Vocabulary%20Recall.Metadata%20Awareness%20After%20Check a aplo-ont:AwarenessObservation ;
    rdf:value "Metadata Awareness After Check"^^xsd:string .

aplo-r:source.Learning%20Platform a aplo-ont:Source ;
    rdf:value "Learning Platform"^^xsd:string .

aplo-r:temporalExtent.Learner%20Alex.Learning%20Platform.Metadata%20Concept%20Check%20Score.2026-01-15T09%3A45%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-01-15T09:45:00+00:00"^^xsd:dateTime .

