aplo-r:learningObjective.OWL%20Modeling%20Practice.Differentiate%20OWL%20data%20and%20object%20properties a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Instructional%20Model.Explain ;
    aplo-ont:developsSkill aplo-r:skill.OWL%20Property%20Differentiation ;
    aplo-ont:hasDescription "Explain how OWL data properties and object properties connect individuals to values or resources"^^xsd:string ;
    aplo-ont:hasName "Differentiate OWL data and object properties"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.OWL%20Modeling%20Practice .

