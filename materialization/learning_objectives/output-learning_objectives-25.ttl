aplo-r:learningObjective.Educational%20KG%20Facilitation%20Planning.Interpret%20RDF%20graph%20statements a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Articulation ;
    aplo-ont:developsSkill aplo-r:skill.RDF%20Graph%20Interpretation ;
    aplo-ont:hasDescription "RDF Graph Interpretation in RDF: Explain the representation choice, then test it against a second example."^^xsd:string ;
    aplo-ont:hasName "Interpret RDF graph statements"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Educational%20KG%20Facilitation%20Planning .

