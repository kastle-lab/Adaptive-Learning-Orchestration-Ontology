aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Identify%20identifier%20patterns a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Coaching ;
    aplo-ont:developsSkill aplo-r:skill.Identifier%20Pattern%20Recognition ;
    aplo-ont:hasDescription "Identifier Pattern Recognition in What is an Identifier?: Compare two alternatives and select the one that best supports the task."^^xsd:string ;
    aplo-ont:hasName "Identify identifier patterns"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Collaborative%20KG%20Delivery%20Planning .

