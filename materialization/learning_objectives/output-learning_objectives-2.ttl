@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.Foundational%20Semantic%20Web%20Study.Describe%20the%20purpose%20of%20a%20knowledge%20graph a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Understand ;
    aplo-ont:developsSkill aplo-r:skill.Knowledge%20Graph%20Purpose%20Explanation ;
    aplo-ont:hasDescription "Describe how entities relationships and schema support knowledge graph representation"^^xsd:string ;
    aplo-ont:hasName "Describe the purpose of a knowledge graph"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Foundational%20Semantic%20Web%20Study .

aplo-r:learningSituation.Foundational%20Semantic%20Web%20Study a aplo-ont:LearningSituation ;
    rdf:value "Foundational Semantic Web Study"^^xsd:string .

aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Understand a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Understand"^^xsd:string .

aplo-r:skill.Knowledge%20Graph%20Purpose%20Explanation a aplo-ont:Skill ;
