aplo-r:learningObjective.KG%20Resource%20Development%20Practice.Map%20GraphQL%20query%20needs a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Universal%20Design%20for%20Learning.Representation%20Options ;
    aplo-ont:developsSkill aplo-r:skill.GraphQL%20Query%20Mapping ;
    aplo-ont:hasDescription "GraphQL Query Mapping in GraphQL: Separate vocabulary recall from modeling judgment in the final answer."^^xsd:string ;
    aplo-ont:hasName "Map GraphQL query needs"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.KG%20Resource%20Development%20Practice .

