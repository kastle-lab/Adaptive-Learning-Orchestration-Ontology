@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.RDF%20Practice%20Session.Interpret%20RDF%20triple%20components a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Articulation ;
    aplo-ont:developsSkill aplo-r:skill.RDF%20Triple%20Interpretation ;
    aplo-ont:hasDescription "Identify subject predicate object class type literals and blank nodes in RDF statements"^^xsd:string ;
    aplo-ont:hasName "Interpret RDF triple components"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.RDF%20Practice%20Session .

aplo-r:learningSituation.RDF%20Practice%20Session a aplo-ont:LearningSituation ;
    rdf:value "RDF Practice Session"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Articulation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Articulation"^^xsd:string .

aplo-r:skill.RDF%20Triple%20Interpretation a aplo-ont:Skill ;
    rdf:value "RDF Triple Interpretation"^^xsd:string .

