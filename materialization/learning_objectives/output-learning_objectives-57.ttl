aplo-r:learningObjective.Consulting%20KG%20Opportunity%20Review.Map%20Open%20Graph%20metadata a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Universal%20Design%20for%20Learning.Representation%20Options ;
    aplo-ont:developsSkill aplo-r:skill.Open%20Graph%20Metadata%20Mapping ;
    aplo-ont:hasDescription "Open Graph Metadata Mapping in Open Graph Protocol: Separate vocabulary recall from modeling judgment in the final answer."^^xsd:string ;
    aplo-ont:hasName "Map Open Graph metadata"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Consulting%20KG%20Opportunity%20Review .

aplo-r:learningSituation.Consulting%20KG%20Opportunity%20Review a aplo-ont:LearningSituation ;
