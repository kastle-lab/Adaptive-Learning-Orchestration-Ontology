@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Analyze%20description%20logic%20constraints a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Conceptual%20Change.Cognitive%20Conflict ;
    aplo-ont:developsSkill aplo-r:skill.Description%20Logic%20Constraint%20Reasoning ;
    aplo-ont:hasDescription "Description Logic Constraint Reasoning in Description Logic: Connect the concept to a tool, schema, or query decision."^^xsd:string ;
    aplo-ont:hasName "Analyze description logic constraints"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Data%20Science%20KG%20Modeling%20Foundations .

aplo-r:learningSituation.Data%20Science%20KG%20Modeling%20Foundations a aplo-ont:LearningSituation ;
    rdf:value "Data Science KG Modeling Foundations"^^xsd:string .

aplo-r:pedagogicalElement.Conceptual%20Change.Cognitive%20Conflict a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Cognitive Conflict"^^xsd:string .

aplo-r:skill.Description%20Logic%20Constraint%20Reasoning a aplo-ont:Skill ;
    rdf:value "Description Logic Constraint Reasoning"^^xsd:string .

