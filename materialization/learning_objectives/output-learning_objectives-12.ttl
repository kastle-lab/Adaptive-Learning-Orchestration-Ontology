aplo-r:learningObjective.Knowledge%20Graph%20Foundations%20Orientation.Recall%20metadata%20vocabulary a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Remember ;
    aplo-ont:developsSkill aplo-r:skill.Metadata%20Vocabulary%20Recall ;
    aplo-ont:hasDescription "Metadata Vocabulary Recall in What is Metadata?: Sort examples and define the boundary conditions for Metadata."^^xsd:string ;
    aplo-ont:hasName "Recall metadata vocabulary"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Knowledge%20Graph%20Foundations%20Orientation .

