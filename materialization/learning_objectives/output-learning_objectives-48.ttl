@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.Secure%20KG%20Implementation%20Training.Align%20models%20with%20upper%20ontology%20concepts a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Universal%20Design%20for%20Learning.Representation%20Options ;
    aplo-ont:developsSkill aplo-r:skill.Upper%20Ontology%20Alignment ;
    aplo-ont:hasDescription "Upper Ontology Alignment in Introduction to Upper Ontologies: Sort examples and define the boundary conditions for Ontology."^^xsd:string ;
    aplo-ont:hasName "Align models with upper ontology concepts"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Secure%20KG%20Implementation%20Training .

aplo-r:learningSituation.Secure%20KG%20Implementation%20Training a aplo-ont:LearningSituation ;
    rdf:value "Secure KG Implementation Training"^^xsd:string .

aplo-r:pedagogicalElement.Universal%20Design%20for%20Learning.Representation%20Options a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Representation Options"^^xsd:string .

aplo-r:skill.Upper%20Ontology%20Alignment a aplo-ont:Skill ;
    rdf:value "Upper Ontology Alignment"^^xsd:string .

