aplo-r:learningObjective.KG%20Curriculum%20Design%20Studio.Plan%20a%20knowledge%20engineering%20workflow a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategic%20Planning ;
    aplo-ont:developsSkill aplo-r:skill.Knowledge%20Engineering%20Workflow%20Planning ;
    aplo-ont:hasDescription "Knowledge Engineering Workflow Planning in Introduction to Knowledge Engineering: Build a concise explanation that another learner could reuse."^^xsd:string ;
    aplo-ont:hasName "Plan a knowledge engineering workflow"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.KG%20Curriculum%20Design%20Studio .

aplo-r:learningSituation.KG%20Curriculum%20Design%20Studio a aplo-ont:LearningSituation ;
