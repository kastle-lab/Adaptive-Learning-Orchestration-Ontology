aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Explain%20ontology%20components a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Modeling ;
    aplo-ont:developsSkill aplo-r:skill.Ontology%20Component%20Explanation ;
    aplo-ont:hasDescription "Ontology Component Explanation in What is an Ontology?: Explain the representation choice, then test it against a second example."^^xsd:string ;
