@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.Ontology%20Contribution%20Modeling%20Practice.Interpret%20propositional%20statements a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Experiential%20Learning%20Cycle.Abstract%20Conceptualization ;
    aplo-ont:developsSkill aplo-r:skill.Propositional%20Statement%20Reasoning ;
    aplo-ont:hasDescription "Propositional Statement Reasoning in Propositional Logic: Revise a flawed example until the terminology and relation choices line up."^^xsd:string ;
    aplo-ont:hasName "Interpret propositional statements"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Ontology%20Contribution%20Modeling%20Practice .

aplo-r:learningSituation.Ontology%20Contribution%20Modeling%20Practice a aplo-ont:LearningSituation ;
    rdf:value "Ontology Contribution Modeling Practice"^^xsd:string .

aplo-r:pedagogicalElement.Experiential%20Learning%20Cycle.Abstract%20Conceptualization a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Abstract Conceptualization"^^xsd:string .

aplo-r:skill.Propositional%20Statement%20Reasoning a aplo-ont:Skill ;
    rdf:value "Propositional Statement Reasoning"^^xsd:string .

