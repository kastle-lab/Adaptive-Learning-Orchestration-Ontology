aplo-r:learningObjective.Executive%20KG%20Value%20Review.Interpret%20predicate%20logic%20statements a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Articulation ;
    aplo-ont:developsSkill aplo-r:skill.Predicate%20Logic%20Statement%20Interpretation ;
