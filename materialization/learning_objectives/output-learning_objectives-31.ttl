@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.KG%20Research%20Representation%20Study.Analyze%20OWL%20modeling%20constraints a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Conceptual%20Change.Cognitive%20Conflict ;
    aplo-ont:developsSkill aplo-r:skill.OWL%20Modeling%20Constraint%20Analysis ;
    aplo-ont:hasDescription "OWL Modeling Constraint Analysis in OWL: Build a concise explanation that another learner could reuse."^^xsd:string ;
    aplo-ont:hasName "Analyze OWL modeling constraints"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.KG%20Research%20Representation%20Study .

aplo-r:learningSituation.KG%20Research%20Representation%20Study a aplo-ont:LearningSituation ;
    rdf:value "KG Research Representation Study"^^xsd:string .

aplo-r:pedagogicalElement.Conceptual%20Change.Cognitive%20Conflict a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Cognitive Conflict"^^xsd:string .

