aplo-r:learningObjective.Ontology%20Contribution%20Modeling%20Practice.Plan%20knowledge%20graph%20documentation a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategic%20Planning ;
    aplo-ont:developsSkill aplo-r:skill.Knowledge%20Graph%20Documentation%20Planning ;
    aplo-ont:hasDescription "Knowledge Graph Documentation Planning in Survey of Documentation Practices: Use the module artifact to defend one explicit design choice."^^xsd:string ;
    aplo-ont:hasName "Plan knowledge graph documentation"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Ontology%20Contribution%20Modeling%20Practice .

aplo-r:learningSituation.Ontology%20Contribution%20Modeling%20Practice a aplo-ont:LearningSituation ;
