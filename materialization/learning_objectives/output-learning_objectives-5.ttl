@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.RDFS%20Schema%20Practice.Apply%20RDFS%20domain%20and%20range%20constraints a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Scaffolding ;
    aplo-ont:developsSkill aplo-r:skill.RDFS%20Schema%20Reasoning ;
    aplo-ont:hasDescription "Use domain range subclass and subproperty ideas to interpret simple RDFS schema statements"^^xsd:string ;
    aplo-ont:hasName "Apply RDFS domain and range constraints"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.RDFS%20Schema%20Practice .

aplo-r:learningSituation.RDFS%20Schema%20Practice a aplo-ont:LearningSituation ;
    rdf:value "RDFS Schema Practice"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Scaffolding a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Scaffolding"^^xsd:string .

aplo-r:skill.RDFS%20Schema%20Reasoning a aplo-ont:Skill ;
    rdf:value "RDFS Schema Reasoning"^^xsd:string .

