aplo-r:learningObjective.Executive%20KG%20Outcome%20Framing.Compare%20OWL%20dialect%20tradeoffs a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Community%20of%20Inquiry.Cognitive%20Presence ;
    aplo-ont:developsSkill aplo-r:skill.OWL%20Dialect%20Selection ;
    aplo-ont:hasDescription "OWL Dialect Selection in OWL Dialects: Connect the concept to a tool, schema, or query decision."^^xsd:string ;
    aplo-ont:hasName "Compare OWL dialect tradeoffs"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Executive%20KG%20Outcome%20Framing .

