aplo-r:learningObjective.KG%20Curriculum%20Design%20Studio.Apply%20set%20relationships a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Scaffolding ;
    aplo-ont:developsSkill aplo-r:skill.Set%20Relationship%20Reasoning ;
    aplo-ont:hasDescription "Set Relationship Reasoning in Introduction to Set Theory: Use the module artifact to defend one explicit design choice."^^xsd:string ;
