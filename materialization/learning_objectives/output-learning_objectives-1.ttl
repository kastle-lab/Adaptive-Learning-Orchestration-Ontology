@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningObjective.Foundational%20Semantic%20Web%20Study.Explain%20what%20an%20ontology%20represents a aplo-ont:LearningObjective ;
    aplo-ont:alignedWith aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Modeling ;
    aplo-ont:developsSkill aplo-r:skill.Ontology%20Concept%20Explanation ;
    aplo-ont:hasDescription "Explain how an ontology organizes classes properties axioms and shared meaning"^^xsd:string ;
    aplo-ont:hasName "Explain what an ontology represents"^^xsd:string ;
    aplo-ont:worksOnSituation aplo-r:learningSituation.Foundational%20Semantic%20Web%20Study .

aplo-r:learningSituation.Foundational%20Semantic%20Web%20Study a aplo-ont:LearningSituation ;
    rdf:value "Foundational Semantic Web Study"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Modeling a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Modeling"^^xsd:string .

aplo-r:skill.Ontology%20Concept%20Explanation a aplo-ont:Skill ;
    rdf:value "Ontology Concept Explanation"^^xsd:string .

