@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalFramework.Cognitive%20Apprenticeship a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasDescription "A framework that makes expert practice visible and then shifts learners toward independent strategic performance"^^xsd:string ;
    aplo-ont:hasElement aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Articulation,
        aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Coaching,
        aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Exploration,
        aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Modeling,
        aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Reflection,
        aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Scaffolding ;
    aplo-ont:hasName "Cognitive Apprenticeship"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Articulation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Articulation"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Coaching a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Coaching"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Exploration a aplo-ont:LastPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Exploration"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Modeling a aplo-ont:FirstPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Modeling"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Reflection a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Reflection"^^xsd:string .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Scaffolding a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Scaffolding"^^xsd:string .

