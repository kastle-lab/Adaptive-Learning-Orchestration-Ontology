@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalFramework.Gradual%20Release%20of%20Responsibility a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasDescription "A teaching framework that shifts responsibility from instructor modeling to learner independence"^^xsd:string ;
    aplo-ont:hasElement aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.I%20Do,
        aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.We%20Do,
        aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.You%20Do%20Independently,
        aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.You%20Do%20Together ;
    aplo-ont:hasName "Gradual Release of Responsibility"^^xsd:string .

aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.I%20Do a aplo-ont:FirstPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "I Do"^^xsd:string .

aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.We%20Do a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "We Do"^^xsd:string .

aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.You%20Do%20Independently a aplo-ont:LastPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "You Do Independently"^^xsd:string .

aplo-r:pedagogicalElement.Gradual%20Release%20of%20Responsibility.You%20Do%20Together a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "You Do Together"^^xsd:string .

