@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalFramework.Scaffolded%20Inquiry a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasDescription "A guided inquiry framework that gradually reduces support as learners build understanding"^^xsd:string ;
    aplo-ont:hasElement aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Activate%20Prior%20Knowledge,
        aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Concept%20Explanation,
        aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Guided%20Investigation,
        aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Independent%20Practice,
        aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Reflection ;
    aplo-ont:hasName "Scaffolded Inquiry"^^xsd:string .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Activate%20Prior%20Knowledge a aplo-ont:FirstPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Activate Prior Knowledge"^^xsd:string .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Concept%20Explanation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Concept Explanation"^^xsd:string .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Guided%20Investigation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Guided Investigation"^^xsd:string .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Independent%20Practice a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Independent Practice"^^xsd:string .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Reflection a aplo-ont:LastPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Reflection"^^xsd:string .

