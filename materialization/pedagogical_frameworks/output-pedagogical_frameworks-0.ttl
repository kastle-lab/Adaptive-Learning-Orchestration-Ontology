@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalFramework.Bloom%27s%20Taxonomy a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasDescription "A hierarchical framework for moving learners from foundational recall toward higher order creation"^^xsd:string ;
    aplo-ont:hasElement aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Analyze,
        aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Apply,
        aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Create,
        aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Evaluate,
        aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Remember,
        aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Understand ;
    aplo-ont:hasName "Bloom's Taxonomy"^^xsd:string .

aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Analyze a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Analyze"^^xsd:string .

aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Apply a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Apply"^^xsd:string .

aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Create a aplo-ont:LastPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Create"^^xsd:string .

aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Evaluate a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Evaluate"^^xsd:string .

aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Remember a aplo-ont:FirstPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Remember"^^xsd:string .

aplo-r:pedagogicalElement.Bloom%27s%20Taxonomy.Understand a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Understand"^^xsd:string .

