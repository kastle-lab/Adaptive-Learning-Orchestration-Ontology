@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalFramework.Self-Regulated%20Learning a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasDescription "A framework for helping learners set goals plan monitor evaluate and adjust their own learning strategies"^^xsd:string ;
    aplo-ont:hasElement aplo-r:pedagogicalElement.Self-Regulated%20Learning.Goal%20Setting,
        aplo-r:pedagogicalElement.Self-Regulated%20Learning.Self%20Evaluation,
        aplo-r:pedagogicalElement.Self-Regulated%20Learning.Self%20Monitoring,
        aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategic%20Planning,
        aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategy%20Adjustment ;
    aplo-ont:hasName "Self-Regulated Learning"^^xsd:string .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Goal%20Setting a aplo-ont:FirstPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Goal Setting"^^xsd:string .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Self%20Evaluation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Self Evaluation"^^xsd:string .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Self%20Monitoring a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Self Monitoring"^^xsd:string .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategic%20Planning a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Strategic Planning"^^xsd:string .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategy%20Adjustment a aplo-ont:LastPedagogicalElement,
        aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Strategy Adjustment"^^xsd:string .

