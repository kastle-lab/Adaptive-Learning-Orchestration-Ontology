@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Elias a aplo-ont:Learner ;
    rdf:value "Learner Elias"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Elias.Triple.RDF%20Graph%20Interpretation.RDF%20Graph%20Interpretation%20Revision%20State .

aplo-r:awarenessLevel.Proficient%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Proficient Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Elias.Triple.RDF%20Graph%20Interpretation.RDF%20Graph%20Interpretation%20Revision%20State a aplo-ont:AwarenessObservation ;
    rdf:value "RDF Graph Interpretation Revision State"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Elias.Triple.RDF%20Graph%20Interpretation.RDF%20Graph%20Interpretation%20Revision%20State.2026-02-14T13%3A56%3A00Z%20to%202026-02-14T14%3A21%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Proficient%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.RDF%20Graph%20Interpretation ;
    aplo-ont:onTopic edu-r:topic.Triple .

aplo-r:skill.RDF%20Graph%20Interpretation a aplo-ont:Skill ;
    rdf:value "RDF Graph Interpretation"^^xsd:string .

aplo-r:temporalExtent.Learner%20Elias.Triple.RDF%20Graph%20Interpretation.RDF%20Graph%20Interpretation%20Revision%20State.2026-02-14T13%3A56%3A00Z%20to%202026-02-14T14%3A21%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-02-14T13:56:00+00:00"^^xsd:dateTime,
        "2026-02-14T14:21:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Triple a edu-ont:Topic ;
    rdf:value "Triple"^^xsd:string .

