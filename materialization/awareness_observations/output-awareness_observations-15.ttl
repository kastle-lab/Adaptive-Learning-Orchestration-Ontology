    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Connie.Conjunction.Propositional%20Statement%20Reasoning.Propositional%20Statement%20Reasoning%20Revision%20State.2026-02-06T13%3A35%3A00Z%20to%202026-02-06T14%3A00%3A00Z ;
