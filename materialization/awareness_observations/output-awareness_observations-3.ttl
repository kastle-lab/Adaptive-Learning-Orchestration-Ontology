@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Blair a aplo-ont:Learner ;
    rdf:value "Learner Blair"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Blair.URI.Linked%20Data%20Identifier%20Recognition.Identifier%20Awareness%20After%20Check .

aplo-r:awarenessLevel.Basic%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Basic Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Blair.URI.Linked%20Data%20Identifier%20Recognition.Identifier%20Awareness%20After%20Check a aplo-ont:AwarenessObservation ;
    rdf:value "Identifier Awareness After Check"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Blair.URI.Linked%20Data%20Identifier%20Recognition.Identifier%20Awareness%20After%20Check.2026-01-15T10%3A00%3A00Z%20to%202026-01-15T10%3A08%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Basic%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Linked%20Data%20Identifier%20Recognition ;
    aplo-ont:onTopic edu-r:topic.URI .

aplo-r:skill.Linked%20Data%20Identifier%20Recognition a aplo-ont:Skill ;
    rdf:value "Linked Data Identifier Recognition"^^xsd:string .

aplo-r:temporalExtent.Learner%20Blair.URI.Linked%20Data%20Identifier%20Recognition.Identifier%20Awareness%20After%20Check.2026-01-15T10%3A00%3A00Z%20to%202026-01-15T10%3A08%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-01-15T10:00:00+00:00"^^xsd:dateTime,
        "2026-01-15T10:08:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.URI a edu-ont:Topic ;
    rdf:value "URI"^^xsd:string .

