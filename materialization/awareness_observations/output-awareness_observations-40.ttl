aplo-r:awarenessObservation.Learner%20Connie.Knowledge%20Graph.Knowledge%20Graph%20Deployment%20Planning.Knowledge%20Graph%20Deployment%20Planning%20Rubric%20Update a aplo-ont:AwarenessObservation ;
    rdf:value "Knowledge Graph Deployment Planning Rubric Update"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Connie.Knowledge%20Graph.Knowledge%20Graph%20Deployment%20Planning.Knowledge%20Graph%20Deployment%20Planning%20Rubric%20Update.2026-03-03T13%3A35%3A00Z%20to%202026-03-03T14%3A00%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Working%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Knowledge%20Graph%20Deployment%20Planning ;
    aplo-ont:onTopic edu-r:topic.Knowledge%20Graph .

aplo-r:skill.Knowledge%20Graph%20Deployment%20Planning a aplo-ont:Skill ;
    rdf:value "Knowledge Graph Deployment Planning"^^xsd:string .

aplo-r:temporalExtent.Learner%20Connie.Knowledge%20Graph.Knowledge%20Graph%20Deployment%20Planning.Knowledge%20Graph%20Deployment%20Planning%20Rubric%20Update.2026-03-03T13%3A35%3A00Z%20to%202026-03-03T14%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-03-03T13:35:00+00:00"^^xsd:dateTime,
        "2026-03-03T14:00:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Knowledge%20Graph a edu-ont:Topic ;
