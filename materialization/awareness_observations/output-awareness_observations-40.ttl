@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Connie a aplo-ont:Learner ;
    rdf:value "Learner Connie"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Connie.Knowledge%20Graph.Knowledge%20Graph%20Deployment%20Planning.Knowledge%20Graph%20Deployment%20Planning%20Rubric%20Update .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
