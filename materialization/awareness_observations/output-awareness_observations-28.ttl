@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Silas a aplo-ont:Learner ;
    rdf:value "Learner Silas"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Silas.OWL.SWRL%20Rule%20Inference%20Explanation.SWRL%20Rule%20Inference%20Explanation%20Practice%20Update .

aplo-r:awarenessLevel.Proficient%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Proficient Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Silas.OWL.SWRL%20Rule%20Inference%20Explanation.SWRL%20Rule%20Inference%20Explanation%20Practice%20Update a aplo-ont:AwarenessObservation ;
    rdf:value "SWRL Rule Inference Explanation Practice Update"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Silas.OWL.SWRL%20Rule%20Inference%20Explanation.SWRL%20Rule%20Inference%20Explanation%20Practice%20Update.2026-02-19T13%3A56%3A00Z%20to%202026-02-19T14%3A21%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Proficient%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.SWRL%20Rule%20Inference%20Explanation ;
    aplo-ont:onTopic edu-r:topic.OWL .

aplo-r:skill.SWRL%20Rule%20Inference%20Explanation a aplo-ont:Skill ;
    rdf:value "SWRL Rule Inference Explanation"^^xsd:string .

aplo-r:temporalExtent.Learner%20Silas.OWL.SWRL%20Rule%20Inference%20Explanation.SWRL%20Rule%20Inference%20Explanation%20Practice%20Update.2026-02-19T13%3A56%3A00Z%20to%202026-02-19T14%3A21%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-02-19T13:56:00+00:00"^^xsd:dateTime,
        "2026-02-19T14:21:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.OWL a edu-ont:Topic ;
    rdf:value "OWL"^^xsd:string .

