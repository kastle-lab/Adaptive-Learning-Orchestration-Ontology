@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Silas a aplo-ont:Learner ;
    rdf:value "Learner Silas"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Silas.Ontology.Semantic%20Web%20History%20Explanation.Semantic%20Web%20History%20Explanation%20Application%20Snapshot .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Working Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Silas.Ontology.Semantic%20Web%20History%20Explanation.Semantic%20Web%20History%20Explanation%20Application%20Snapshot a aplo-ont:AwarenessObservation ;
    rdf:value "Semantic Web History Explanation Application Snapshot"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Silas.Ontology.Semantic%20Web%20History%20Explanation.Semantic%20Web%20History%20Explanation%20Application%20Snapshot.2026-03-12T14%3A03%3A00Z%20to%202026-03-12T14%3A28%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Working%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Semantic%20Web%20History%20Explanation ;
    aplo-ont:onTopic edu-r:topic.Ontology .

aplo-r:skill.Semantic%20Web%20History%20Explanation a aplo-ont:Skill ;
    rdf:value "Semantic Web History Explanation"^^xsd:string .

aplo-r:temporalExtent.Learner%20Silas.Ontology.Semantic%20Web%20History%20Explanation.Semantic%20Web%20History%20Explanation%20Application%20Snapshot.2026-03-12T14%3A03%3A00Z%20to%202026-03-12T14%3A28%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-03-12T14:03:00+00:00"^^xsd:dateTime,
        "2026-03-12T14:28:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Ontology a edu-ont:Topic ;
    rdf:value "Ontology"^^xsd:string .

