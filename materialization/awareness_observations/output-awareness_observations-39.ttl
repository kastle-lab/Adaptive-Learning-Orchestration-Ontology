aplo-r:learner.Learner%20Elias a aplo-ont:Learner ;
    rdf:value "Learner Elias"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Elias.Ontology.Protege%20Ontology%20Editing.Protege%20Ontology%20Editing%20Revision%20State .

