    rdf:value "Protege Ontology Editing Revision State"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Elias.Ontology.Protege%20Ontology%20Editing.Protege%20Ontology%20Editing%20Revision%20State.2026-03-02T14%3A03%3A00Z%20to%202026-03-02T14%3A28%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Basic%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Protege%20Ontology%20Editing ;
