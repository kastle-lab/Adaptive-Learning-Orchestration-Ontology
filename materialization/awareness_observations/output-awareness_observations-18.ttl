@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Darwin a aplo-ont:Learner ;
    rdf:value "Learner Darwin"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Darwin.Expressivity.Description%20Logic%20Constraint%20Reasoning.Description%20Logic%20Constraint%20Reasoning%20Checkpoint .

aplo-r:awarenessLevel.Proficient%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Proficient Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Darwin.Expressivity.Description%20Logic%20Constraint%20Reasoning.Description%20Logic%20Constraint%20Reasoning%20Checkpoint a aplo-ont:AwarenessObservation ;
    rdf:value "Description Logic Constraint Reasoning Checkpoint"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Darwin.Expressivity.Description%20Logic%20Constraint%20Reasoning.Description%20Logic%20Constraint%20Reasoning%20Checkpoint.2026-02-09T13%3A56%3A00Z%20to%202026-02-09T14%3A21%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Proficient%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Description%20Logic%20Constraint%20Reasoning ;
    aplo-ont:onTopic edu-r:topic.Expressivity .

aplo-r:skill.Description%20Logic%20Constraint%20Reasoning a aplo-ont:Skill ;
    rdf:value "Description Logic Constraint Reasoning"^^xsd:string .

aplo-r:temporalExtent.Learner%20Darwin.Expressivity.Description%20Logic%20Constraint%20Reasoning.Description%20Logic%20Constraint%20Reasoning%20Checkpoint.2026-02-09T13%3A56%3A00Z%20to%202026-02-09T14%3A21%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-02-09T13:56:00+00:00"^^xsd:dateTime,
        "2026-02-09T14:21:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Expressivity a edu-ont:Topic ;
    rdf:value "Expressivity"^^xsd:string .

