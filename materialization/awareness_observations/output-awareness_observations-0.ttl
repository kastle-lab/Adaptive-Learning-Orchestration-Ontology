@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Alex a aplo-ont:Learner ;
    rdf:value "Learner Alex"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Alex.Knowledge%20Graph.Knowledge%20Graph%20Purpose%20Explanation.Knowledge%20Graph%20Initial%20Awareness .

aplo-r:awarenessLevel.Low%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Low Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Alex.Knowledge%20Graph.Knowledge%20Graph%20Purpose%20Explanation.Knowledge%20Graph%20Initial%20Awareness a aplo-ont:AwarenessObservation ;
    rdf:value "Knowledge Graph Initial Awareness"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Alex.Knowledge%20Graph.Knowledge%20Graph%20Purpose%20Explanation.Knowledge%20Graph%20Initial%20Awareness.2026-01-14T09%3A00%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Low%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Knowledge%20Graph%20Purpose%20Explanation ;
    aplo-ont:onTopic edu-r:topic.Knowledge%20Graph .

aplo-r:skill.Knowledge%20Graph%20Purpose%20Explanation a aplo-ont:Skill ;
    rdf:value "Knowledge Graph Purpose Explanation"^^xsd:string .

aplo-r:temporalExtent.Learner%20Alex.Knowledge%20Graph.Knowledge%20Graph%20Purpose%20Explanation.Knowledge%20Graph%20Initial%20Awareness.2026-01-14T09%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-01-14T09:00:00+00:00"^^xsd:dateTime .

edu-r:topic.Knowledge%20Graph a edu-ont:Topic ;
    rdf:value "Knowledge Graph"^^xsd:string .

