aplo-r:learner.Learner%20Darwin a aplo-ont:Learner ;
    rdf:value "Learner Darwin"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Darwin.Schema.Knowledge%20Graph%20Structure%20Explanation.Knowledge%20Graph%20Structure%20Explanation%20Practice%20Update .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
