aplo-r:awarenessObservation.Learner%20Darwin.Schema.Knowledge%20Graph%20Structure%20Explanation.Knowledge%20Graph%20Structure%20Explanation%20Practice%20Update a aplo-ont:AwarenessObservation ;
    rdf:value "Knowledge Graph Structure Explanation Practice Update"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Darwin.Schema.Knowledge%20Graph%20Structure%20Explanation.Knowledge%20Graph%20Structure%20Explanation%20Practice%20Update.2026-02-03T13%3A49%3A00Z%20to%202026-02-03T14%3A14%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Working%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Knowledge%20Graph%20Structure%20Explanation ;
    aplo-ont:onTopic edu-r:topic.Schema .

aplo-r:skill.Knowledge%20Graph%20Structure%20Explanation a aplo-ont:Skill ;
    rdf:value "Knowledge Graph Structure Explanation"^^xsd:string .

aplo-r:temporalExtent.Learner%20Darwin.Schema.Knowledge%20Graph%20Structure%20Explanation.Knowledge%20Graph%20Structure%20Explanation%20Practice%20Update.2026-02-03T13%3A49%3A00Z%20to%202026-02-03T14%3A14%3A00Z a aplo-ont:TemporalExtent ;
