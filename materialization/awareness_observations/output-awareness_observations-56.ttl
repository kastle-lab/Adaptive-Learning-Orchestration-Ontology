@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Morgan a aplo-ont:Learner ;
    rdf:value "Learner Morgan"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Morgan.Query.SPARQL%20Query%20Pattern%20Construction.SPARQL%20Query%20Pattern%20Readiness%20Observation .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Working Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Morgan.Query.SPARQL%20Query%20Pattern%20Construction.SPARQL%20Query%20Pattern%20Readiness%20Observation a aplo-ont:AwarenessObservation ;
    rdf:value "SPARQL Query Pattern Readiness Observation"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Morgan.Query.SPARQL%20Query%20Pattern%20Construction.SPARQL%20Query%20Pattern%20Readiness%20Observation.2026-03-19T13%3A00%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Working%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.SPARQL%20Query%20Pattern%20Construction ;
    aplo-ont:onTopic edu-r:topic.Query .

aplo-r:skill.SPARQL%20Query%20Pattern%20Construction a aplo-ont:Skill ;
    rdf:value "SPARQL Query Pattern Construction"^^xsd:string .

aplo-r:temporalExtent.Learner%20Morgan.Query.SPARQL%20Query%20Pattern%20Construction.SPARQL%20Query%20Pattern%20Readiness%20Observation.2026-03-19T13%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
    time:inXSDDateTime "2026-03-19T13:00:00+00:00"^^xsd:dateTime .

edu-r:topic.Query a edu-ont:Topic ;
    rdf:value "Query"^^xsd:string .

