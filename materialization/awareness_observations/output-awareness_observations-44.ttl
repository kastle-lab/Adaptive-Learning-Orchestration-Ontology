    rdf:value "Knowledge Graph Documentation Planning Practice Update"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Connie.Metadata.Knowledge%20Graph%20Documentation%20Planning.Knowledge%20Graph%20Documentation%20Planning%20Practice%20Update.2026-03-07T14%3A03%3A00Z%20to%202026-03-07T14%3A28%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Basic%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Knowledge%20Graph%20Documentation%20Planning ;
    aplo-ont:onTopic edu-r:topic.Metadata .

aplo-r:skill.Knowledge%20Graph%20Documentation%20Planning a aplo-ont:Skill ;
