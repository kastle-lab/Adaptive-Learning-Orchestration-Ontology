aplo-r:learner.Learner%20Connie a aplo-ont:Learner ;
    rdf:value "Learner Connie"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Connie.Metadata.Knowledge%20Graph%20Documentation%20Planning.Knowledge%20Graph%20Documentation%20Planning%20Practice%20Update .

aplo-r:awarenessLevel.Basic%20Awareness a aplo-ont:AwarenessLevel ;
