@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Oratius a aplo-ont:Learner ;
    rdf:value "Learner Oratius"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Oratius.Functionality.Discrete%20Relation%20Property%20Recognition.Discrete%20Relation%20Property%20Recognition%20Scenario%20Update .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Working Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Oratius.Functionality.Discrete%20Relation%20Property%20Recognition.Discrete%20Relation%20Property%20Recognition%20Scenario%20Update a aplo-ont:AwarenessObservation ;
    rdf:value "Discrete Relation Property Recognition Scenario Update"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Oratius.Functionality.Discrete%20Relation%20Property%20Recognition.Discrete%20Relation%20Property%20Recognition%20Scenario%20Update.2026-02-12T13%3A42%3A00Z%20to%202026-02-12T14%3A07%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Working%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Discrete%20Relation%20Property%20Recognition ;
    aplo-ont:onTopic edu-r:topic.Functionality .

aplo-r:skill.Discrete%20Relation%20Property%20Recognition a aplo-ont:Skill ;
    rdf:value "Discrete Relation Property Recognition"^^xsd:string .

aplo-r:temporalExtent.Learner%20Oratius.Functionality.Discrete%20Relation%20Property%20Recognition.Discrete%20Relation%20Property%20Recognition%20Scenario%20Update.2026-02-12T13%3A42%3A00Z%20to%202026-02-12T14%3A07%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-02-12T13:42:00+00:00"^^xsd:dateTime,
        "2026-02-12T14:07:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Functionality a edu-ont:Topic ;
    rdf:value "Functionality"^^xsd:string .

