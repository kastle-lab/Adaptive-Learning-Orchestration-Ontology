@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Courtney a aplo-ont:Learner ;
    rdf:value "Learner Courtney"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Courtney.Inference.Datalog%20Rule%20Interpretation.Datalog%20Rule%20Interpretation%20Rubric%20Update .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Working Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Courtney.Inference.Datalog%20Rule%20Interpretation.Datalog%20Rule%20Interpretation%20Rubric%20Update a aplo-ont:AwarenessObservation ;
    rdf:value "Datalog Rule Interpretation Rubric Update"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Courtney.Inference.Datalog%20Rule%20Interpretation.Datalog%20Rule%20Interpretation%20Rubric%20Update.2026-02-07T13%3A42%3A00Z%20to%202026-02-07T14%3A07%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Working%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Datalog%20Rule%20Interpretation ;
    aplo-ont:onTopic edu-r:topic.Inference .

aplo-r:skill.Datalog%20Rule%20Interpretation a aplo-ont:Skill ;
    rdf:value "Datalog Rule Interpretation"^^xsd:string .

aplo-r:temporalExtent.Learner%20Courtney.Inference.Datalog%20Rule%20Interpretation.Datalog%20Rule%20Interpretation%20Rubric%20Update.2026-02-07T13%3A42%3A00Z%20to%202026-02-07T14%3A07%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-02-07T13:42:00+00:00"^^xsd:dateTime,
        "2026-02-07T14:07:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Inference a edu-ont:Topic ;
    rdf:value "Inference"^^xsd:string .

