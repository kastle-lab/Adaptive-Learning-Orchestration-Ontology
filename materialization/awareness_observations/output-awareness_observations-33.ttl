@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Connie a aplo-ont:Learner ;
    rdf:value "Learner Connie"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Connie.rangeIncludes.Schema.org%20Vocabulary%20Alignment.Schema.org%20Vocabulary%20Alignment%20Application%20Snapshot .

aplo-r:awarenessLevel.Mastery%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Mastery Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Connie.rangeIncludes.Schema.org%20Vocabulary%20Alignment.Schema.org%20Vocabulary%20Alignment%20Application%20Snapshot a aplo-ont:AwarenessObservation ;
    rdf:value "Schema.org Vocabulary Alignment Application Snapshot"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Connie.rangeIncludes.Schema.org%20Vocabulary%20Alignment.Schema.org%20Vocabulary%20Alignment%20Application%20Snapshot.2026-02-24T13%3A56%3A00Z%20to%202026-02-24T14%3A21%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Mastery%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Schema.org%20Vocabulary%20Alignment ;
    aplo-ont:onTopic edu-r:topic.rangeIncludes .

aplo-r:skill.Schema.org%20Vocabulary%20Alignment a aplo-ont:Skill ;
    rdf:value "Schema.org Vocabulary Alignment"^^xsd:string .

aplo-r:temporalExtent.Learner%20Connie.rangeIncludes.Schema.org%20Vocabulary%20Alignment.Schema.org%20Vocabulary%20Alignment%20Application%20Snapshot.2026-02-24T13%3A56%3A00Z%20to%202026-02-24T14%3A21%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-02-24T13:56:00+00:00"^^xsd:dateTime,
        "2026-02-24T14:21:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.rangeIncludes a edu-ont:Topic ;
    rdf:value "rangeIncludes"^^xsd:string .

