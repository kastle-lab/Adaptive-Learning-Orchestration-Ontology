@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Ethan a aplo-ont:Learner ;
    rdf:value "Learner Ethan"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Ethan.Metadata.Metadata%20Vocabulary%20Recall.Metadata%20Example%20Sortpoint .

aplo-r:awarenessLevel.Basic%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Basic Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Ethan.Metadata.Metadata%20Vocabulary%20Recall.Metadata%20Example%20Sortpoint a aplo-ont:AwarenessObservation ;
    rdf:value "Metadata Example Sortpoint"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Ethan.Metadata.Metadata%20Vocabulary%20Recall.Metadata%20Example%20Sortpoint.2026-02-01T13%3A35%3A00Z%20to%202026-02-01T14%3A00%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Basic%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Metadata%20Vocabulary%20Recall ;
    aplo-ont:onTopic edu-r:topic.Metadata .

aplo-r:skill.Metadata%20Vocabulary%20Recall a aplo-ont:Skill ;
    rdf:value "Metadata Vocabulary Recall"^^xsd:string .

aplo-r:temporalExtent.Learner%20Ethan.Metadata.Metadata%20Vocabulary%20Recall.Metadata%20Example%20Sortpoint.2026-02-01T13%3A35%3A00Z%20to%202026-02-01T14%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-02-01T13:35:00+00:00"^^xsd:dateTime,
        "2026-02-01T14:00:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Metadata a edu-ont:Topic ;
    rdf:value "Metadata"^^xsd:string .

