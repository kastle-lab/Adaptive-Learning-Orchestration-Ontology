    rdf:value "RDF Serialization Current Awareness"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Blair.RDF%2FXML.RDF%20Serialization%20Comparison.RDF%20Serialization%20Current%20Awareness.2026-01-17T12%3A00%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Low%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.RDF%20Serialization%20Comparison ;
