aplo-r:temporalExtent.Learner%20Blair.RDF%2FXML.RDF%20Serialization%20Comparison.RDF%20Serialization%20Current%20Awareness.2026-01-17T12%3A00%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "ISO 8601 UTC"^^xsd:string,
        "PointInTime"^^xsd:string ;
