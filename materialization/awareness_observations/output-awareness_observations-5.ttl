aplo-r:learner.Learner%20Blair a aplo-ont:Learner ;
    rdf:value "Learner Blair"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Blair.RDF%2FXML.RDF%20Serialization%20Comparison.RDF%20Serialization%20Current%20Awareness .

aplo-r:awarenessLevel.Low%20Awareness a aplo-ont:AwarenessLevel ;
