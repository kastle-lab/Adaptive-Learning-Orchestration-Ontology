    aplo-ont:onSkill aplo-r:skill.Predicate%20Logic%20Statement%20Interpretation ;
    aplo-ont:onTopic edu-r:topic.Predicate .

aplo-r:skill.Predicate%20Logic%20Statement%20Interpretation a aplo-ont:Skill ;
