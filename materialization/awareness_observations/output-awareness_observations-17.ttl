aplo-r:temporalExtent.Learner%20Edward.Predicate.Predicate%20Logic%20Statement%20Interpretation.Predicate%20Logic%20Statement%20Interpretation%20Application%20Snapshot.2026-02-08T13%3A49%3A00Z%20to%202026-02-08T14%3A14%3A00Z a aplo-ont:TemporalExtent ;
