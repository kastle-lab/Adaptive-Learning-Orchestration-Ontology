aplo-r:learner.Learner%20Edward a aplo-ont:Learner ;
    rdf:value "Learner Edward"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Edward.Predicate.Predicate%20Logic%20Statement%20Interpretation.Predicate%20Logic%20Statement%20Interpretation%20Application%20Snapshot .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
