@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Courtney a aplo-ont:Learner ;
    rdf:value "Learner Courtney"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Courtney.Query.Triplestore%20Selection.Triplestore%20Selection%20Rubric%20Update .

aplo-r:awarenessLevel.Basic%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Basic Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Courtney.Query.Triplestore%20Selection.Triplestore%20Selection%20Rubric%20Update a aplo-ont:AwarenessObservation ;
    rdf:value "Triplestore Selection Rubric Update"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Courtney.Query.Triplestore%20Selection.Triplestore%20Selection%20Rubric%20Update.2026-03-11T13%3A56%3A00Z%20to%202026-03-11T14%3A21%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Basic%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.Triplestore%20Selection ;
    aplo-ont:onTopic edu-r:topic.Query .

aplo-r:skill.Triplestore%20Selection a aplo-ont:Skill ;
    rdf:value "Triplestore Selection"^^xsd:string .

aplo-r:temporalExtent.Learner%20Courtney.Query.Triplestore%20Selection.Triplestore%20Selection%20Rubric%20Update.2026-03-11T13%3A56%3A00Z%20to%202026-03-11T14%3A21%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-03-11T13:56:00+00:00"^^xsd:dateTime,
        "2026-03-11T14:21:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Query a edu-ont:Topic ;
    rdf:value "Query"^^xsd:string .

