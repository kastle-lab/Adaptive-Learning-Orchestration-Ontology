    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Alex.Ontology.Ontology%20Concept%20Explanation.Ontology%20Awareness%20After%20Review.2026-01-16T14%3A00%3A00Z%20to%202026-01-16T14%3A25%3A00Z ;
