@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Casey a aplo-ont:Learner ;
    rdf:value "Learner Casey"^^xsd:string ;
    aplo-ont:hasAwarenessObservation aplo-r:awarenessObservation.Learner%20Casey.Schema.RDFS%20Schema%20Reasoning.RDFS%20Schema%20Awareness%20After%20Review .

aplo-r:awarenessLevel.Working%20Awareness a aplo-ont:AwarenessLevel ;
    rdf:value "Working Awareness"^^xsd:string .

aplo-r:awarenessObservation.Learner%20Casey.Schema.RDFS%20Schema%20Reasoning.RDFS%20Schema%20Awareness%20After%20Review a aplo-ont:AwarenessObservation ;
    rdf:value "RDFS Schema Awareness After Review"^^xsd:string ;
    aplo-ont:atTime aplo-r:temporalExtent.Learner%20Casey.Schema.RDFS%20Schema%20Reasoning.RDFS%20Schema%20Awareness%20After%20Review.2026-01-18T15%3A00%3A00Z%20to%202026-01-18T15%3A20%3A00Z ;
    aplo-ont:hasAwarenessLevel aplo-r:awarenessLevel.Working%20Awareness ;
    aplo-ont:onSkill aplo-r:skill.RDFS%20Schema%20Reasoning ;
    aplo-ont:onTopic edu-r:topic.Schema .

aplo-r:skill.RDFS%20Schema%20Reasoning a aplo-ont:Skill ;
    rdf:value "RDFS Schema Reasoning"^^xsd:string .

aplo-r:temporalExtent.Learner%20Casey.Schema.RDFS%20Schema%20Reasoning.RDFS%20Schema%20Awareness%20After%20Review.2026-01-18T15%3A00%3A00Z%20to%202026-01-18T15%3A20%3A00Z a aplo-ont:TemporalExtent ;
    rdf:value "2026-01-18T15:00:00+00:00"^^xsd:dateTime,
        "2026-01-18T15:20:00+00:00"^^xsd:dateTime,
        "ISO 8601 UTC"^^xsd:string,
        "TimeInterval"^^xsd:string .

edu-r:topic.Schema a edu-ont:Topic ;
    rdf:value "Schema"^^xsd:string .

