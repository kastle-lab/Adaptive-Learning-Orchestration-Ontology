@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.OWL a edu-ont:Media ;
    rdf:value "OWL"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.OWL.OWL%20Constraint%20Modeling%20Review ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.KG%20Research%20Representation%20Study.Analyze%20OWL%20modeling%20constraints .

aplo-r:evaluationAssessmentExercise.OWL.OWL%20Constraint%20Modeling%20Review a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "OWL Constraint Modeling Review"^^xsd:string .

aplo-r:learningObjective.KG%20Research%20Representation%20Study.Analyze%20OWL%20modeling%20constraints a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Analyze OWL modeling constraints"^^xsd:string .

