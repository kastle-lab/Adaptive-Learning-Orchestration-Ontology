@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.Dublin%20Core a edu-ont:Media ;
    rdf:value "Dublin Core"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Dublin%20Core.Dublin%20Core%20Metadata%20Mapping%20Task ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.Executive%20KG%20Value%20Review.Map%20Dublin%20Core%20metadata%20fields .

aplo-r:evaluationAssessmentExercise.Dublin%20Core.Dublin%20Core%20Metadata%20Mapping%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Dublin Core Metadata Mapping Task"^^xsd:string .

aplo-r:learningObjective.Executive%20KG%20Value%20Review.Map%20Dublin%20Core%20metadata%20fields a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Map Dublin Core metadata fields"^^xsd:string .

