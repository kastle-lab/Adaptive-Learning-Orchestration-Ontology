@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.Introduction%20to%20Logic a edu-ont:Media ;
    rdf:value "Introduction to Logic"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Introduction%20to%20Logic.Logic%20Operator%20Mini%20Quiz ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Recognize%20logic%20operators .

aplo-r:evaluationAssessmentExercise.Introduction%20to%20Logic.Logic%20Operator%20Mini%20Quiz a aplo-ont:EvaluationAssessmentExercise ;
