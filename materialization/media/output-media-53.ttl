edu-r:media.Entailment%20Regimes a edu-ont:Media ;
    rdf:value "Entailment Regimes"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Entailment%20Regimes.Entailment%20Regime%20Selection%20Scenario ;
