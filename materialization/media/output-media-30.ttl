@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.OWL%20Dialects a edu-ont:Media ;
    rdf:value "OWL Dialects"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.OWL%20Dialects.OWL%20Dialect%20Selection%20Brief ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.Executive%20KG%20Outcome%20Framing.Compare%20OWL%20dialect%20tradeoffs .

aplo-r:evaluationAssessmentExercise.OWL%20Dialects.OWL%20Dialect%20Selection%20Brief a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "OWL Dialect Selection Brief"^^xsd:string .

aplo-r:learningObjective.Executive%20KG%20Outcome%20Framing.Compare%20OWL%20dialect%20tradeoffs a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Compare OWL dialect tradeoffs"^^xsd:string .

