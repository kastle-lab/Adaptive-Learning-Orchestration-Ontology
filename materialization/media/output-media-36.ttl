@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.PROV-O a edu-ont:Media ;
    rdf:value "PROV-O"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.PROV-O.Provenance%20Chain%20Modeling%20Task ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Model%20provenance%20relationships%20with%20PROV-O .

aplo-r:evaluationAssessmentExercise.PROV-O.Provenance%20Chain%20Modeling%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Provenance Chain Modeling Task"^^xsd:string .

aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Model%20provenance%20relationships%20with%20PROV-O a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Model provenance relationships with PROV-O"^^xsd:string .

