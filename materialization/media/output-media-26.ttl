@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.Introduction%20to%20Discrete%20Mathematics a edu-ont:Media ;
    rdf:value "Introduction to Discrete Mathematics"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Introduction%20to%20Discrete%20Mathematics.Relation%20Property%20Classification ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.Ontology%20Vocabulary%20Modeling%20Review.Recognize%20discrete%20relation%20properties .

aplo-r:evaluationAssessmentExercise.Introduction%20to%20Discrete%20Mathematics.Relation%20Property%20Classification a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Relation Property Classification"^^xsd:string .

aplo-r:learningObjective.Ontology%20Vocabulary%20Modeling%20Review.Recognize%20discrete%20relation%20properties a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Recognize discrete relation properties"^^xsd:string .

