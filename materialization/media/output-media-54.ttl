@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.RDF%20Plus a edu-ont:Media ;
    rdf:value "RDF Plus"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.RDF%20Plus.RDF%20Plus%20Property%20Reasoning%20Drill ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.Executive%20KG%20Value%20Review.Explain%20RDF%20Plus%20property%20reasoning .

aplo-r:evaluationAssessmentExercise.RDF%20Plus.RDF%20Plus%20Property%20Reasoning%20Drill a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "RDF Plus Property Reasoning Drill"^^xsd:string .

aplo-r:learningObjective.Executive%20KG%20Value%20Review.Explain%20RDF%20Plus%20property%20reasoning a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Explain RDF Plus property reasoning"^^xsd:string .

