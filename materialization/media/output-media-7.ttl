@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:media.What%20is%20an%20Identifier%3F a edu-ont:Media ;
    rdf:value "What is an Identifier?"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.What%20is%20an%20Identifier%3F.Identifier%20Pattern%20Sorting%20Task ;
    aplo-ont:supportsLearningObjective aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Identify%20identifier%20patterns .

aplo-r:evaluationAssessmentExercise.What%20is%20an%20Identifier%3F.Identifier%20Pattern%20Sorting%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Identifier Pattern Sorting Task"^^xsd:string .

aplo-r:learningObjective.Collaborative%20KG%20Delivery%20Planning.Identify%20identifier%20patterns a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Identify identifier patterns"^^xsd:string .

