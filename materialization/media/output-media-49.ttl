edu-r:media.History%20of%20the%20Semantic%20Web a edu-ont:Media ;
    rdf:value "History of the Semantic Web"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.History%20of%20the%20Semantic%20Web.Semantic%20Web%20Timeline%20Explanation ;
