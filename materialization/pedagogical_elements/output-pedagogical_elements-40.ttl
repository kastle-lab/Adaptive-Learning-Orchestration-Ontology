@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Modeling a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Make expert reasoning visible by demonstrating the target task decisions and tradeoffs"^^xsd:string ;
    aplo-ont:hasName "Modeling"^^xsd:string ;
    aplo-ont:hasNextPedagogicalElement aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Coaching ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Cognitive%20Apprenticeship .

aplo-r:pedagogicalElement.Cognitive%20Apprenticeship.Coaching a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Coaching"^^xsd:string .

aplo-r:pedagogicalFramework.Cognitive%20Apprenticeship a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Cognitive Apprenticeship"^^xsd:string .

