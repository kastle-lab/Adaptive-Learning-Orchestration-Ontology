@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Instructional%20Model.Elaborate a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Extend learning to new situations examples or applications"^^xsd:string ;
    aplo-ont:hasName "Elaborate"^^xsd:string ;
    aplo-ont:hasNextPedagogicalElement aplo-r:pedagogicalElement.Instructional%20Model.Evaluate ;
    aplo-ont:hasPreviousPedagogicalElement aplo-r:pedagogicalElement.Instructional%20Model.Explain ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Instructional%20Model .

aplo-r:pedagogicalElement.Instructional%20Model.Evaluate a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Evaluate"^^xsd:string .

aplo-r:pedagogicalElement.Instructional%20Model.Explain a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Explain"^^xsd:string .

aplo-r:pedagogicalFramework.Instructional%20Model a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Instructional Model"^^xsd:string .

