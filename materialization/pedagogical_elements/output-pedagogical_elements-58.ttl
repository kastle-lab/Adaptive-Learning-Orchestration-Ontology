@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Project%20Based%20Learning.Public%20Product a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Produce a shareable artifact demonstration model or recommendation for an authentic audience"^^xsd:string ;
    aplo-ont:hasName "Public Product"^^xsd:string ;
    aplo-ont:hasNextPedagogicalElement aplo-r:pedagogicalElement.Project%20Based%20Learning.Project%20Reflection ;
    aplo-ont:hasPreviousPedagogicalElement aplo-r:pedagogicalElement.Project%20Based%20Learning.Critique%20and%20Revision ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Project%20Based%20Learning .

aplo-r:pedagogicalElement.Project%20Based%20Learning.Critique%20and%20Revision a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Critique and Revision"^^xsd:string .

aplo-r:pedagogicalElement.Project%20Based%20Learning.Project%20Reflection a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Project Reflection"^^xsd:string .

aplo-r:pedagogicalFramework.Project%20Based%20Learning a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Project Based Learning"^^xsd:string .

