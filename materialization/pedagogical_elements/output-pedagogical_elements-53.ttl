@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Collaborative%20Learning.Joint%20Construction a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Create a shared model explanation query artifact or design decision through coordinated contribution"^^xsd:string ;
    aplo-ont:hasName "Joint Construction"^^xsd:string ;
    aplo-ont:hasNextPedagogicalElement aplo-r:pedagogicalElement.Collaborative%20Learning.Group%20Reflection ;
    aplo-ont:hasPreviousPedagogicalElement aplo-r:pedagogicalElement.Collaborative%20Learning.Peer%20Negotiation ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Collaborative%20Learning .

aplo-r:pedagogicalElement.Collaborative%20Learning.Group%20Reflection a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Group Reflection"^^xsd:string .

aplo-r:pedagogicalElement.Collaborative%20Learning.Peer%20Negotiation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Peer Negotiation"^^xsd:string .

aplo-r:pedagogicalFramework.Collaborative%20Learning a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Collaborative Learning"^^xsd:string .

