@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Self%20Evaluation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Judge current performance against criteria evidence or prior goals"^^xsd:string ;
    aplo-ont:hasName "Self Evaluation"^^xsd:string ;
    aplo-ont:hasNextPedagogicalElement aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategy%20Adjustment ;
    aplo-ont:hasPreviousPedagogicalElement aplo-r:pedagogicalElement.Self-Regulated%20Learning.Self%20Monitoring ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Self-Regulated%20Learning .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Self%20Monitoring a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Self Monitoring"^^xsd:string .

aplo-r:pedagogicalElement.Self-Regulated%20Learning.Strategy%20Adjustment a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Strategy Adjustment"^^xsd:string .

aplo-r:pedagogicalFramework.Self-Regulated%20Learning a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Self-Regulated Learning"^^xsd:string .

