@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Independent%20Practice a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Ask learners to apply the idea with reduced guidance"^^xsd:string ;
    aplo-ont:hasName "Independent Practice"^^xsd:string ;
    aplo-ont:hasNextPedagogicalElement aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Reflection ;
    aplo-ont:hasPreviousPedagogicalElement aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Concept%20Explanation ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Scaffolded%20Inquiry .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Concept%20Explanation a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Concept Explanation"^^xsd:string .

aplo-r:pedagogicalElement.Scaffolded%20Inquiry.Reflection a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Reflection"^^xsd:string .

aplo-r:pedagogicalFramework.Scaffolded%20Inquiry a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Scaffolded Inquiry"^^xsd:string .

