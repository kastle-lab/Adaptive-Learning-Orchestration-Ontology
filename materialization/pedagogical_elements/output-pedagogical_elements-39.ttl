@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Community%20of%20Inquiry.Teaching%20Presence a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Design facilitate and direct learning activity so the inquiry stays coherent and purposeful"^^xsd:string ;
    aplo-ont:hasName "Teaching Presence"^^xsd:string ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Community%20of%20Inquiry .

aplo-r:pedagogicalFramework.Community%20of%20Inquiry a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Community of Inquiry"^^xsd:string .

