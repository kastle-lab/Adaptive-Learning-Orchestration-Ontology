@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalElement.Problem%20Based%20Learning.Presentation%20and%20Reflection a aplo-ont:PedagogicalElement ;
    aplo-ont:hasDescription "Learners present their solution and reflect on evidence process and limitations"^^xsd:string ;
    aplo-ont:hasName "Presentation and Reflection"^^xsd:string ;
    aplo-ont:hasPreviousPedagogicalElement aplo-r:pedagogicalElement.Problem%20Based%20Learning.Solution%20Development ;
    aplo-ont:isElementOf aplo-r:pedagogicalFramework.Problem%20Based%20Learning .

aplo-r:pedagogicalElement.Problem%20Based%20Learning.Solution%20Development a aplo-ont:PedagogicalElement ;
    aplo-ont:hasName "Solution Development"^^xsd:string .

aplo-r:pedagogicalFramework.Problem%20Based%20Learning a aplo-ont:PedagogicalFramework ;
    aplo-ont:hasName "Problem Based Learning"^^xsd:string .

