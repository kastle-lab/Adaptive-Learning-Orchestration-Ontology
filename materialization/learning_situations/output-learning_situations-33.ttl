@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learningSituation.Ontology%20Vocabulary%20Modeling%20Review a aplo-ont:LearningSituation ;
    rdf:value "Ontology Vocabulary Modeling Review"^^xsd:string ;
    aplo-ont:requiresTopicKnowledge edu-r:topic.Axiom,
        edu-r:topic.OWL,
        edu-r:topic.Property ;
    aplo-ont:scopes edu-r:persona.Oratius .

edu-r:persona.Oratius a edu-ont:Persona ;
    rdf:value "Oratius"^^xsd:string .

edu-r:topic.Axiom a edu-ont:Topic ;
    rdf:value "Axiom"^^xsd:string .

edu-r:topic.OWL a edu-ont:Topic ;
    rdf:value "OWL"^^xsd:string .

edu-r:topic.Property a edu-ont:Topic ;
    rdf:value "Property"^^xsd:string .

