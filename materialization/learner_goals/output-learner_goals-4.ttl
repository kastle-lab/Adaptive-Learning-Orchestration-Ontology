@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learnerGoal.Implement%20Knowledge%20Graph%20Developer%20Workflow a aplo-ont:LearnerGoal ;
    rdf:value "Implement Knowledge Graph Developer Workflow"^^xsd:string ;
    aplo-ont:targetsSkill aplo-r:skill.Entailment%20Regime%20Selection,
        aplo-r:skill.Ontology%20Component%20Explanation,
        aplo-r:skill.SPARQL%20Query%20Pattern%20Construction .

aplo-r:skill.Entailment%20Regime%20Selection a aplo-ont:Skill ;
    rdf:value "Entailment Regime Selection"^^xsd:string .

aplo-r:skill.Ontology%20Component%20Explanation a aplo-ont:Skill ;
    rdf:value "Ontology Component Explanation"^^xsd:string .

aplo-r:skill.SPARQL%20Query%20Pattern%20Construction a aplo-ont:Skill ;
    rdf:value "SPARQL Query Pattern Construction"^^xsd:string .

