@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learnerGoal.Demonstrate%20KG%20Tool%20Value%20to%20Users a aplo-ont:LearnerGoal ;
    rdf:value "Demonstrate KG Tool Value to Users"^^xsd:string ;
    aplo-ont:targetsSkill aplo-r:skill.Knowledge%20Graph%20Visualization%20Tool%20Selection,
        aplo-r:skill.RDF%20Serialization%20Format%20Comparison .

aplo-r:skill.Knowledge%20Graph%20Visualization%20Tool%20Selection a aplo-ont:Skill ;
