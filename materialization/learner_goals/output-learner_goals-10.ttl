@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learnerGoal.Coordinate%20Collaborative%20KG%20Delivery a aplo-ont:LearnerGoal ;
    rdf:value "Coordinate Collaborative KG Delivery"^^xsd:string ;
    aplo-ont:targetsSkill aplo-r:skill.Identifier%20Pattern%20Recognition,
        aplo-r:skill.Provenance%20Relationship%20Modeling .

aplo-r:skill.Identifier%20Pattern%20Recognition a aplo-ont:Skill ;
    rdf:value "Identifier Pattern Recognition"^^xsd:string .

aplo-r:skill.Provenance%20Relationship%20Modeling a aplo-ont:Skill ;
    rdf:value "Provenance Relationship Modeling"^^xsd:string .

