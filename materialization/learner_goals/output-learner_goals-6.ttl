@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learnerGoal.Lead%20Modular%20Ontology%20Modeling a aplo-ont:LearnerGoal ;
    rdf:value "Lead Modular Ontology Modeling"^^xsd:string ;
    aplo-ont:targetsSkill aplo-r:skill.Knowledge%20Graph%20Deployment%20Planning,
        aplo-r:skill.Knowledge%20Graph%20Documentation%20Planning,
        aplo-r:skill.Modular%20Ontology%20Design,
        aplo-r:skill.Ontology%20Tool%20Selection,
        aplo-r:skill.Propositional%20Statement%20Reasoning,
        aplo-r:skill.Schema.org%20Vocabulary%20Alignment .

aplo-r:skill.Knowledge%20Graph%20Deployment%20Planning a aplo-ont:Skill ;
    rdf:value "Knowledge Graph Deployment Planning"^^xsd:string .

aplo-r:skill.Knowledge%20Graph%20Documentation%20Planning a aplo-ont:Skill ;
    rdf:value "Knowledge Graph Documentation Planning"^^xsd:string .

aplo-r:skill.Modular%20Ontology%20Design a aplo-ont:Skill ;
    rdf:value "Modular Ontology Design"^^xsd:string .

aplo-r:skill.Ontology%20Tool%20Selection a aplo-ont:Skill ;
    rdf:value "Ontology Tool Selection"^^xsd:string .

aplo-r:skill.Propositional%20Statement%20Reasoning a aplo-ont:Skill ;
    rdf:value "Propositional Statement Reasoning"^^xsd:string .

aplo-r:skill.Schema.org%20Vocabulary%20Alignment a aplo-ont:Skill ;
    rdf:value "Schema.org Vocabulary Alignment"^^xsd:string .

