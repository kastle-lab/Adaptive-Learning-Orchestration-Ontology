@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.OWL.OWL%20Constraint%20Modeling%20Review a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "OWL"^^xsd:string,
        "OWL Constraint Modeling Review"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.Data%20Properties,
        edu-r:topic.Datatypes,
        edu-r:topic.OWL,
        edu-r:topic.OWL2 ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Moderate%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Short%20Explanation%20Rubric .

edu-r:topic.Data%20Properties a edu-ont:Topic ;
    rdf:value "Data Properties"^^xsd:string .

edu-r:topic.Datatypes a edu-ont:Topic ;
    rdf:value "Datatypes"^^xsd:string .

edu-r:topic.OWL a edu-ont:Topic ;
    rdf:value "OWL"^^xsd:string .

edu-r:topic.OWL2 a edu-ont:Topic ;
    rdf:value "OWL2"^^xsd:string .

aplo-r:evaluationTechnique.Short%20Explanation%20Rubric a aplo-ont:EvaluationTechnique ;
    rdf:value "Short Explanation Rubric"^^xsd:string .

aplo-r:workloadLevel.Moderate%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Moderate Workload"^^xsd:string .

