@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.Survey%20of%20Modeling%20Tools.Modeling%20Tool%20Selection%20Matrix a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Modeling Tool Selection Matrix"^^xsd:string,
        "Survey of Modeling Tools"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.DataWorld,
        edu-r:topic.PoolParty,
        edu-r:topic.Protege,
        edu-r:topic.TopBraid%20Composer ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Moderate%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Short%20Explanation%20Rubric .

edu-r:topic.DataWorld a edu-ont:Topic ;
    rdf:value "DataWorld"^^xsd:string .

edu-r:topic.PoolParty a edu-ont:Topic ;
    rdf:value "PoolParty"^^xsd:string .

edu-r:topic.Protege a edu-ont:Topic ;
    rdf:value "Protege"^^xsd:string .

edu-r:topic.TopBraid%20Composer a edu-ont:Topic ;
    rdf:value "TopBraid Composer"^^xsd:string .

aplo-r:evaluationTechnique.Short%20Explanation%20Rubric a aplo-ont:EvaluationTechnique ;
    rdf:value "Short Explanation Rubric"^^xsd:string .

aplo-r:workloadLevel.Moderate%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Moderate Workload"^^xsd:string .

