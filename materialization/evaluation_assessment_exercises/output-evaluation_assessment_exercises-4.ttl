@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.RDF.RDF%20Triple%20Interpretation%20Quiz a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "RDF"^^xsd:string,
        "RDF Triple Interpretation Quiz"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.Triple ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Moderate%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Triple%20Interpretation%20Quiz .

edu-r:topic.Triple a edu-ont:Topic ;
    rdf:value "Triple"^^xsd:string .

aplo-r:evaluationTechnique.Triple%20Interpretation%20Quiz a aplo-ont:EvaluationTechnique ;
    rdf:value "Triple Interpretation Quiz"^^xsd:string .

aplo-r:workloadLevel.Moderate%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Moderate Workload"^^xsd:string .

