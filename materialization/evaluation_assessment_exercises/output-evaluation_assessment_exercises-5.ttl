@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.RDFS.RDFS%20Schema%20Reasoning%20Exercise a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "RDFS"^^xsd:string,
        "RDFS Schema Reasoning Exercise"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.Schema ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Moderate%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Schema%20Reasoning%20Review .

edu-r:topic.Schema a edu-ont:Topic ;
    rdf:value "Schema"^^xsd:string .

aplo-r:evaluationTechnique.Schema%20Reasoning%20Review a aplo-ont:EvaluationTechnique ;
    rdf:value "Schema Reasoning Review"^^xsd:string .

aplo-r:workloadLevel.Moderate%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Moderate Workload"^^xsd:string .

