@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.Introduction%20to%20Knowledge%20Engineering.Knowledge%20Engineering%20Workflow%20Plan a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Introduction to Knowledge Engineering"^^xsd:string,
        "Knowledge Engineering Workflow Plan"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.Knowledge%20Graph ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Moderate%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Short%20Explanation%20Rubric .

edu-r:topic.Knowledge%20Graph a edu-ont:Topic ;
    rdf:value "Knowledge Graph"^^xsd:string .

aplo-r:evaluationTechnique.Short%20Explanation%20Rubric a aplo-ont:EvaluationTechnique ;
    rdf:value "Short Explanation Rubric"^^xsd:string .

aplo-r:workloadLevel.Moderate%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Moderate Workload"^^xsd:string .

