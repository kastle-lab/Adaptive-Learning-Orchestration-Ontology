@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.Introduction%20to%20Set%20Theory.Set%20Relationship%20Diagram%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Introduction to Set Theory"^^xsd:string,
        "Set Relationship Diagram Task"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.Disjointness,
        edu-r:topic.Disjunction,
        edu-r:topic.Intersection,
        edu-r:topic.Union ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Low%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Auto%20Scored%20Concept%20Check .

edu-r:topic.Disjointness a edu-ont:Topic ;
    rdf:value "Disjointness"^^xsd:string .

edu-r:topic.Disjunction a edu-ont:Topic ;
    rdf:value "Disjunction"^^xsd:string .

edu-r:topic.Intersection a edu-ont:Topic ;
    rdf:value "Intersection"^^xsd:string .

edu-r:topic.Union a edu-ont:Topic ;
    rdf:value "Union"^^xsd:string .

aplo-r:evaluationTechnique.Auto%20Scored%20Concept%20Check a aplo-ont:EvaluationTechnique ;
    rdf:value "Auto Scored Concept Check"^^xsd:string .

aplo-r:workloadLevel.Low%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Low Workload"^^xsd:string .

