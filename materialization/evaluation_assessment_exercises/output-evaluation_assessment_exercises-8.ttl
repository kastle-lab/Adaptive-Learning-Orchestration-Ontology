@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.OWL.OWL%20Modeling%20Review a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "OWL"^^xsd:string,
        "OWL Modeling Review"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.OWL ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Moderate%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Ontology%20Modeling%20Review .

edu-r:topic.OWL a edu-ont:Topic ;
    rdf:value "OWL"^^xsd:string .

aplo-r:evaluationTechnique.Ontology%20Modeling%20Review a aplo-ont:EvaluationTechnique ;
    rdf:value "Ontology Modeling Review"^^xsd:string .

aplo-r:workloadLevel.Moderate%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Moderate Workload"^^xsd:string .

