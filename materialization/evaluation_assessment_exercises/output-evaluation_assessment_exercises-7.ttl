@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:evaluationAssessmentExercise.SPARQL.SPARQL%20Select%20Query%20Exercise a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "SPARQL"^^xsd:string,
        "SPARQL Select Query Exercise"^^xsd:string ;
    aplo-ont:evaluatesTopicAwarenessOf edu-r:topic.Query ;
    aplo-ont:hasWorkloadLevel aplo-r:workloadLevel.Moderate%20Workload ;
    aplo-ont:usesTechnique aplo-r:evaluationTechnique.Query%20Practice%20Check .

edu-r:topic.Query a edu-ont:Topic ;
    rdf:value "Query"^^xsd:string .

aplo-r:evaluationTechnique.Query%20Practice%20Check a aplo-ont:EvaluationTechnique ;
    rdf:value "Query Practice Check"^^xsd:string .

aplo-r:workloadLevel.Moderate%20Workload a aplo-ont:WorkloadLevel ;
    rdf:value "Moderate Workload"^^xsd:string .

