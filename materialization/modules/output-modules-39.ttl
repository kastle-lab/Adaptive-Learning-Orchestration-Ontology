@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Protege a edu-ont:Module ;
    rdf:value "Protege"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Protege.Protege%20Editing%20Lab ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Educational%20KG%20Facilitation%20Planning.Edit%20ontology%20models%20in%20Protege .

aplo-r:evaluationAssessmentExercise.Protege.Protege%20Editing%20Lab a aplo-ont:EvaluationAssessmentExercise ;
