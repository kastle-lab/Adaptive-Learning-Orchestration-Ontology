@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Survey%20of%20Triplestores a edu-ont:Module ;
    rdf:value "Survey of Triplestores"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Survey%20of%20Triplestores.Triplestore%20Selection%20Matrix ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Data%20Analysis%20KG%20Modeling%20Practice.Compare%20triplestore%20options .

aplo-r:evaluationAssessmentExercise.Survey%20of%20Triplestores.Triplestore%20Selection%20Matrix a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Triplestore Selection Matrix"^^xsd:string .

aplo-r:learningObjective.Data%20Analysis%20KG%20Modeling%20Practice.Compare%20triplestore%20options a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Compare triplestore options"^^xsd:string .

