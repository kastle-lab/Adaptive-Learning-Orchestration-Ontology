@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.SPARQL a edu-ont:Module ;
    rdf:value "SPARQL"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.SPARQL.SPARQL%20Query%20Repair%20Task ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Construct%20SPARQL%20query%20patterns .

aplo-r:evaluationAssessmentExercise.SPARQL.SPARQL%20Query%20Repair%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "SPARQL Query Repair Task"^^xsd:string .

aplo-r:learningObjective.Developer%20Knowledge%20Graph%20Implementation%20Practice.Construct%20SPARQL%20query%20patterns a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Construct SPARQL query patterns"^^xsd:string .

