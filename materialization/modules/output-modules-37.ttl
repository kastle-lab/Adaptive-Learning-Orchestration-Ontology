@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.SKOS a edu-ont:Module ;
    rdf:value "SKOS"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.SKOS.Concept%20Scheme%20Modeling%20Task ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Ontology%20Vocabulary%20Modeling%20Review.Model%20SKOS%20concept%20schemes .

aplo-r:evaluationAssessmentExercise.SKOS.Concept%20Scheme%20Modeling%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Concept Scheme Modeling Task"^^xsd:string .

aplo-r:learningObjective.Ontology%20Vocabulary%20Modeling%20Review.Model%20SKOS%20concept%20schemes a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Model SKOS concept schemes"^^xsd:string .

