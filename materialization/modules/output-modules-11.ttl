@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.RDFS a edu-ont:Module ;
    rdf:value "RDFS"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.RDFS.RDFS%20Vocabulary%20Inference%20Review ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.KG%20Resource%20Development%20Practice.Apply%20RDFS%20vocabulary%20reasoning .

aplo-r:evaluationAssessmentExercise.RDFS.RDFS%20Vocabulary%20Inference%20Review a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "RDFS Vocabulary Inference Review"^^xsd:string .

aplo-r:learningObjective.KG%20Resource%20Development%20Practice.Apply%20RDFS%20vocabulary%20reasoning a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Apply RDFS vocabulary reasoning"^^xsd:string .

