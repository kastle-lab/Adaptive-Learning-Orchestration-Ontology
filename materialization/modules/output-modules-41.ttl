@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Introduction%20to%20Knowledge%20Engineering a edu-ont:Module ;
    rdf:value "Introduction to Knowledge Engineering"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Introduction%20to%20Knowledge%20Engineering.Knowledge%20Engineering%20Workflow%20Plan ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.KG%20Curriculum%20Design%20Studio.Plan%20a%20knowledge%20engineering%20workflow .

aplo-r:evaluationAssessmentExercise.Introduction%20to%20Knowledge%20Engineering.Knowledge%20Engineering%20Workflow%20Plan a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Knowledge Engineering Workflow Plan"^^xsd:string .

aplo-r:learningObjective.KG%20Curriculum%20Design%20Studio.Plan%20a%20knowledge%20engineering%20workflow a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Plan a knowledge engineering workflow"^^xsd:string .

