@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Rules a edu-ont:Module ;
    rdf:value "Rules"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Rules.Rule%20Inference%20Trace ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Consulting%20KG%20Opportunity%20Review.Explain%20rule%20based%20inference .

aplo-r:evaluationAssessmentExercise.Rules.Rule%20Inference%20Trace a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Rule Inference Trace"^^xsd:string .

aplo-r:learningObjective.Consulting%20KG%20Opportunity%20Review.Explain%20rule%20based%20inference a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Explain rule based inference"^^xsd:string .

