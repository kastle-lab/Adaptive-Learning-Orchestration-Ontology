@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Description%20Logic a edu-ont:Module ;
    rdf:value "Description Logic"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Description%20Logic.Description%20Logic%20Constraint%20Review ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Analyze%20description%20logic%20constraints .

aplo-r:evaluationAssessmentExercise.Description%20Logic.Description%20Logic%20Constraint%20Review a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Description Logic Constraint Review"^^xsd:string .

aplo-r:learningObjective.Data%20Science%20KG%20Modeling%20Foundations.Analyze%20description%20logic%20constraints a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Analyze description logic constraints"^^xsd:string .

