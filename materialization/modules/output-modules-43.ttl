@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.GraphQL a edu-ont:Module ;
    rdf:value "GraphQL"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.GraphQL.GraphQL%20Mapping%20Exercise ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.KG%20Resource%20Development%20Practice.Map%20GraphQL%20query%20needs .

aplo-r:evaluationAssessmentExercise.GraphQL.GraphQL%20Mapping%20Exercise a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "GraphQL Mapping Exercise"^^xsd:string .

aplo-r:learningObjective.KG%20Resource%20Development%20Practice.Map%20GraphQL%20query%20needs a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Map GraphQL query needs"^^xsd:string .

