@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Introduction%20to%20Set%20Theory a edu-ont:Module ;
    rdf:value "Introduction to Set Theory"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Introduction%20to%20Set%20Theory.Set%20Relationship%20Diagram%20Task ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.KG%20Curriculum%20Design%20Studio.Apply%20set%20relationships .

aplo-r:evaluationAssessmentExercise.Introduction%20to%20Set%20Theory.Set%20Relationship%20Diagram%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Set Relationship Diagram Task"^^xsd:string .

aplo-r:learningObjective.KG%20Curriculum%20Design%20Studio.Apply%20set%20relationships a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Apply set relationships"^^xsd:string .

