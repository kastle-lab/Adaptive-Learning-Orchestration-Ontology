@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.RDF%20Serializations a edu-ont:Module ;
    rdf:value "RDF Serializations"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.RDF%20Serializations.RDF%20Serialization%20Comparison ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.RDF%20Practice%20Session.Compare%20RDF%20serialization%20formats .

aplo-r:evaluationAssessmentExercise.RDF%20Serializations.RDF%20Serialization%20Comparison a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "RDF Serialization Comparison"^^xsd:string .

aplo-r:learningObjective.RDF%20Practice%20Session.Compare%20RDF%20serialization%20formats a aplo-ont:LearningObjective ;
