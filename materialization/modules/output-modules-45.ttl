@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Survey%20of%20Visualization%20Tools a edu-ont:Module ;
    rdf:value "Survey of Visualization Tools"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Survey%20of%20Visualization%20Tools.Visualization%20Tool%20Selection%20Brief ;
