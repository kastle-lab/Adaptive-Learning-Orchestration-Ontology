@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Propositional%20Logic a edu-ont:Module ;
    rdf:value "Propositional Logic"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Propositional%20Logic.Proposition%20Truth%20Table%20Task ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Ontology%20Contribution%20Modeling%20Practice.Interpret%20propositional%20statements .

aplo-r:evaluationAssessmentExercise.Propositional%20Logic.Proposition%20Truth%20Table%20Task a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Proposition Truth Table Task"^^xsd:string .

aplo-r:learningObjective.Ontology%20Contribution%20Modeling%20Practice.Interpret%20propositional%20statements a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Interpret propositional statements"^^xsd:string .

