@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.SOSA%20%26%20SSN a edu-ont:Module ;
    rdf:value "SOSA & SSN"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.SOSA%20%26%20SSN.Observation%20Modeling%20Scenario ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Consulting%20KG%20Opportunity%20Review.Model%20observations%20with%20SOSA%20SSN .

aplo-r:evaluationAssessmentExercise.SOSA%20%26%20SSN.Observation%20Modeling%20Scenario a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Observation Modeling Scenario"^^xsd:string .

aplo-r:learningObjective.Consulting%20KG%20Opportunity%20Review.Model%20observations%20with%20SOSA%20SSN a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Model observations with SOSA SSN"^^xsd:string .

