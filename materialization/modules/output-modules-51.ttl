@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Nanopublications a edu-ont:Module ;
    rdf:value "Nanopublications"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Nanopublications.Nanopublication%20Claim%20Card ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Executive%20KG%20Outcome%20Framing.Model%20nanopublication%20claims .

aplo-r:evaluationAssessmentExercise.Nanopublications.Nanopublication%20Claim%20Card a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Nanopublication Claim Card"^^xsd:string .

aplo-r:learningObjective.Executive%20KG%20Outcome%20Framing.Model%20nanopublication%20claims a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Model nanopublication claims"^^xsd:string .

