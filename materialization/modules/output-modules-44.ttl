@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Survey%20of%20Documentation%20Practices a edu-ont:Module ;
    rdf:value "Survey of Documentation Practices"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Survey%20of%20Documentation%20Practices.Documentation%20Coverage%20Review ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Ontology%20Contribution%20Modeling%20Practice.Plan%20knowledge%20graph%20documentation .

aplo-r:evaluationAssessmentExercise.Survey%20of%20Documentation%20Practices.Documentation%20Coverage%20Review a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Documentation Coverage Review"^^xsd:string .

aplo-r:learningObjective.Ontology%20Contribution%20Modeling%20Practice.Plan%20knowledge%20graph%20documentation a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Plan knowledge graph documentation"^^xsd:string .

