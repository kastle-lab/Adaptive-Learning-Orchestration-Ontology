@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

edu-r:module.Introduction%20to%20Upper%20Ontologies a edu-ont:Module ;
    rdf:value "Introduction to Upper Ontologies"^^xsd:string ;
    aplo-ont:hasAssessmentExercise aplo-r:evaluationAssessmentExercise.Introduction%20to%20Upper%20Ontologies.Upper%20Ontology%20Alignment%20Review ;
    aplo-ont:hasLearningObjective aplo-r:learningObjective.Secure%20KG%20Implementation%20Training.Align%20models%20with%20upper%20ontology%20concepts .

aplo-r:evaluationAssessmentExercise.Introduction%20to%20Upper%20Ontologies.Upper%20Ontology%20Alignment%20Review a aplo-ont:EvaluationAssessmentExercise ;
    rdf:value "Upper Ontology Alignment Review"^^xsd:string .

aplo-r:learningObjective.Secure%20KG%20Implementation%20Training.Align%20models%20with%20upper%20ontology%20concepts a aplo-ont:LearningObjective ;
    aplo-ont:hasName "Align models with upper ontology concepts"^^xsd:string .

