@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:skill.RDF%20Graph%20Interpretation a aplo-ont:Skill ;
    rdf:value "RDF Graph Interpretation"^^xsd:string ;
    aplo-ont:requiresTopic edu-r:topic.Blank%20Node,
        edu-r:topic.Blank%20Nodes,
        edu-r:topic.Class,
        edu-r:topic.Literals,
        edu-r:topic.Namespace,
        edu-r:topic.Namespaces,
        edu-r:topic.Object,
        edu-r:topic.Predicate,
        edu-r:topic.Property,
        edu-r:topic.Subject,
        edu-r:topic.Triple,
        edu-r:topic.Type .

edu-r:topic.Blank%20Node a edu-ont:Topic ;
    rdf:value "Blank Node"^^xsd:string .

edu-r:topic.Blank%20Nodes a edu-ont:Topic ;
    rdf:value "Blank Nodes"^^xsd:string .

edu-r:topic.Class a edu-ont:Topic ;
    rdf:value "Class"^^xsd:string .

edu-r:topic.Literals a edu-ont:Topic ;
    rdf:value "Literals"^^xsd:string .

edu-r:topic.Namespace a edu-ont:Topic ;
    rdf:value "Namespace"^^xsd:string .

edu-r:topic.Namespaces a edu-ont:Topic ;
    rdf:value "Namespaces"^^xsd:string .

edu-r:topic.Object a edu-ont:Topic ;
    rdf:value "Object"^^xsd:string .

edu-r:topic.Predicate a edu-ont:Topic ;
    rdf:value "Predicate"^^xsd:string .

edu-r:topic.Property a edu-ont:Topic ;
    rdf:value "Property"^^xsd:string .

edu-r:topic.Subject a edu-ont:Topic ;
    rdf:value "Subject"^^xsd:string .

edu-r:topic.Triple a edu-ont:Topic ;
    rdf:value "Triple"^^xsd:string .

edu-r:topic.Type a edu-ont:Topic ;
    rdf:value "Type"^^xsd:string .

