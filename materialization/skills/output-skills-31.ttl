@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:skill.OWL%20Modeling%20Constraint%20Analysis a aplo-ont:Skill ;
    rdf:value "OWL Modeling Constraint Analysis"^^xsd:string ;
    aplo-ont:requiresTopic edu-r:topic.Annotations,
        edu-r:topic.Anonymous%20Class,
        edu-r:topic.Axiom,
        edu-r:topic.Data%20Properties,
        edu-r:topic.Datatypes,
        edu-r:topic.Equivalence,
        edu-r:topic.OWL,
        edu-r:topic.OWL2,
        edu-r:topic.Object%20Properties .

edu-r:topic.Annotations a edu-ont:Topic ;
    rdf:value "Annotations"^^xsd:string .

edu-r:topic.Anonymous%20Class a edu-ont:Topic ;
    rdf:value "Anonymous Class"^^xsd:string .

edu-r:topic.Axiom a edu-ont:Topic ;
    rdf:value "Axiom"^^xsd:string .

edu-r:topic.Data%20Properties a edu-ont:Topic ;
    rdf:value "Data Properties"^^xsd:string .

edu-r:topic.Datatypes a edu-ont:Topic ;
    rdf:value "Datatypes"^^xsd:string .

edu-r:topic.Equivalence a edu-ont:Topic ;
    rdf:value "Equivalence"^^xsd:string .

edu-r:topic.OWL a edu-ont:Topic ;
    rdf:value "OWL"^^xsd:string .

edu-r:topic.OWL2 a edu-ont:Topic ;
    rdf:value "OWL2"^^xsd:string .

edu-r:topic.Object%20Properties a edu-ont:Topic ;
    rdf:value "Object Properties"^^xsd:string .

