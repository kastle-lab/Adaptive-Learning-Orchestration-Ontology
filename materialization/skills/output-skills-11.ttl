@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:skill.RDF%20RDFS%20Mastery%20Demonstration a aplo-ont:Skill ;
    rdf:value "RDF RDFS Mastery Demonstration"^^xsd:string ;
    aplo-ont:requiresTopic edu-r:topic.Domain,
        edu-r:topic.Range,
        edu-r:topic.Schema,
        edu-r:topic.Triple .

edu-r:topic.Domain a edu-ont:Topic ;
    rdf:value "Domain"^^xsd:string .

edu-r:topic.Range a edu-ont:Topic ;
    rdf:value "Range"^^xsd:string .

edu-r:topic.Schema a edu-ont:Topic ;
    rdf:value "Schema"^^xsd:string .

edu-r:topic.Triple a edu-ont:Topic ;
    rdf:value "Triple"^^xsd:string .

