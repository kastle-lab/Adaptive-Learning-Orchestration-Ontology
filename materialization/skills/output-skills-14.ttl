@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:skill.Knowledge%20Graph%20Structure%20Explanation a aplo-ont:Skill ;
    rdf:value "Knowledge Graph Structure Explanation"^^xsd:string ;
    aplo-ont:requiresTopic edu-r:topic.Schema,
        edu-r:topic.Statement,
        edu-r:topic.Triple .

edu-r:topic.Schema a edu-ont:Topic ;
    rdf:value "Schema"^^xsd:string .

edu-r:topic.Statement a edu-ont:Topic ;
    rdf:value "Statement"^^xsd:string .

edu-r:topic.Triple a edu-ont:Topic ;
    rdf:value "Triple"^^xsd:string .

