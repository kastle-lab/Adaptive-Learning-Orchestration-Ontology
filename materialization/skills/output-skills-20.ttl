@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:skill.Description%20Logic%20Constraint%20Reasoning a aplo-ont:Skill ;
    rdf:value "Description Logic Constraint Reasoning"^^xsd:string ;
    aplo-ont:requiresTopic edu-r:topic.Expressivity,
        edu-r:topic.Inference .

edu-r:topic.Expressivity a edu-ont:Topic ;
    rdf:value "Expressivity"^^xsd:string .

edu-r:topic.Inference a edu-ont:Topic ;
    rdf:value "Inference"^^xsd:string .

