@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix edu-ont: <https://edugate.cs.wright.edu/lod/ontology#> .
@prefix edu-r: <https://edugate.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:skill.RDFS%20Vocabulary%20Reasoning a aplo-ont:Skill ;
    rdf:value "RDFS Vocabulary Reasoning"^^xsd:string ;
    aplo-ont:requiresTopic edu-r:topic.Domain%20Restrictions,
        edu-r:topic.Range%20Restrictions,
        edu-r:topic.Subclass,
        edu-r:topic.Subproperty .

edu-r:topic.Domain%20Restrictions a edu-ont:Topic ;
    rdf:value "Domain Restrictions"^^xsd:string .

edu-r:topic.Range%20Restrictions a edu-ont:Topic ;
    rdf:value "Range Restrictions"^^xsd:string .

edu-r:topic.Subclass a edu-ont:Topic ;
    rdf:value "Subclass"^^xsd:string .

edu-r:topic.Subproperty a edu-ont:Topic ;
    rdf:value "Subproperty"^^xsd:string .

