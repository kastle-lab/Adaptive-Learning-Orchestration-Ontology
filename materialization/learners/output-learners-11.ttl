@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Oratius a aplo-ont:Learner ;
    rdf:value "Learner Oratius"^^xsd:string ;
    aplo-ont:hasGoal aplo-r:learnerGoal.Refine%20Ontology%20Vocabulary%20Modeling ;
    aplo-ont:hasLearnerPreference aplo-r:learnerPreference.Immediate%20Feedback%20Preference,
        aplo-r:learnerPreference.Worked%20Examples%20Preference ;
    aplo-ont:hasLearningChallenge aplo-r:learningChallenge.Needs%20Advanced%20Modeling%20Depth,
        aplo-r:learningChallenge.Needs%20Collaborative%20Review%20Support ;
    aplo-ont:hasSituation aplo-r:learningSituation.Ontology%20Vocabulary%20Modeling%20Review .

aplo-r:learnerGoal.Refine%20Ontology%20Vocabulary%20Modeling a aplo-ont:LearnerGoal ;
    rdf:value "Refine Ontology Vocabulary Modeling"^^xsd:string .

aplo-r:learnerPreference.Immediate%20Feedback%20Preference a aplo-ont:LearnerPreference ;
    rdf:value "Immediate Feedback Preference"^^xsd:string .

aplo-r:learnerPreference.Worked%20Examples%20Preference a aplo-ont:LearnerPreference ;
    rdf:value "Worked Examples Preference"^^xsd:string .

aplo-r:learningChallenge.Needs%20Advanced%20Modeling%20Depth a aplo-ont:LearningChallenge ;
    rdf:value "Needs Advanced Modeling Depth"^^xsd:string .

aplo-r:learningChallenge.Needs%20Collaborative%20Review%20Support a aplo-ont:LearningChallenge ;
    rdf:value "Needs Collaborative Review Support"^^xsd:string .

aplo-r:learningSituation.Ontology%20Vocabulary%20Modeling%20Review a aplo-ont:LearningSituation ;
    rdf:value "Ontology Vocabulary Modeling Review"^^xsd:string .

