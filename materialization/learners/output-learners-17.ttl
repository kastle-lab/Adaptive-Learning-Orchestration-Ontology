@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Silas a aplo-ont:Learner ;
    rdf:value "Learner Silas"^^xsd:string ;
    aplo-ont:hasGoal aplo-r:learnerGoal.Evaluate%20Supply%20Chain%20KG%20Use%20Cases ;
    aplo-ont:hasLearnerPreference aplo-r:learnerPreference.Immediate%20Feedback%20Preference,
        aplo-r:learnerPreference.Worked%20Examples%20Preference ;
    aplo-ont:hasLearningChallenge aplo-r:learningChallenge.Limited%20Study%20Time ;
    aplo-ont:hasSituation aplo-r:learningSituation.Supply%20Chain%20KG%20Use%20Case%20Review .

aplo-r:learnerGoal.Evaluate%20Supply%20Chain%20KG%20Use%20Cases a aplo-ont:LearnerGoal ;
    rdf:value "Evaluate Supply Chain KG Use Cases"^^xsd:string .

aplo-r:learnerPreference.Immediate%20Feedback%20Preference a aplo-ont:LearnerPreference ;
    rdf:value "Immediate Feedback Preference"^^xsd:string .

aplo-r:learnerPreference.Worked%20Examples%20Preference a aplo-ont:LearnerPreference ;
    rdf:value "Worked Examples Preference"^^xsd:string .

aplo-r:learningChallenge.Limited%20Study%20Time a aplo-ont:LearningChallenge ;
    rdf:value "Limited Study Time"^^xsd:string .

aplo-r:learningSituation.Supply%20Chain%20KG%20Use%20Case%20Review a aplo-ont:LearningSituation ;
    rdf:value "Supply Chain KG Use Case Review"^^xsd:string .

