@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:learner.Learner%20Casey a aplo-ont:Learner ;
    rdf:value "Learner Casey"^^xsd:string ;
    aplo-ont:hasGoal aplo-r:learnerGoal.Improve%20Ontology%20Modeling%20Decisions ;
    aplo-ont:hasLearnerPreference aplo-r:learnerPreference.Project%20Context%20Preference ;
    aplo-ont:hasLearningChallenge aplo-r:learningChallenge.Needs%20Corrective%20Modeling%20Feedback ;
    aplo-ont:hasSituation aplo-r:learningSituation.OWL%20Modeling%20Practice .

aplo-r:learnerGoal.Improve%20Ontology%20Modeling%20Decisions a aplo-ont:LearnerGoal ;
    rdf:value "Improve Ontology Modeling Decisions"^^xsd:string .

aplo-r:learnerPreference.Project%20Context%20Preference a aplo-ont:LearnerPreference ;
    rdf:value "Project Context Preference"^^xsd:string .

aplo-r:learningChallenge.Needs%20Corrective%20Modeling%20Feedback a aplo-ont:LearningChallenge ;
    rdf:value "Needs Corrective Modeling Feedback"^^xsd:string .

aplo-r:learningSituation.OWL%20Modeling%20Practice a aplo-ont:LearningSituation ;
    rdf:value "OWL Modeling Practice"^^xsd:string .

