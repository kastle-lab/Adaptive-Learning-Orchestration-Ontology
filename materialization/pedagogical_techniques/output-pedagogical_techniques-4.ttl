@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalTechnique.Socratic%20Questioning a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasDescription "Use sequenced questions to reveal assumptions evidence and reasoning"^^xsd:string ;
    aplo-ont:hasName "Socratic Questioning"^^xsd:string ;
    aplo-ont:servesPedagogicalObjective aplo-r:pedagogicalObjective.Develop%20Critical%20Thinking .

aplo-r:pedagogicalObjective.Develop%20Critical%20Thinking a aplo-ont:PedagogicalObjective ;
    aplo-ont:hasDescription "Help learners examine reasoning and justify claims with evidence"^^xsd:string ;
    aplo-ont:hasName "Develop Critical Thinking"^^xsd:string .

