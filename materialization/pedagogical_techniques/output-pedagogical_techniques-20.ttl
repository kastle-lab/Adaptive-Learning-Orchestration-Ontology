@prefix aplo-ont: <https://aplo.cs.wright.edu/lod/ontology#> .
@prefix aplo-r: <https://aplo.cs.wright.edu/lod/resource#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aplo-r:pedagogicalTechnique.Self%20Explanation a aplo-ont:PedagogicalTechnique ;
    aplo-ont:hasDescription "Ask learners to explain each decision step relation or inference in their own words"^^xsd:string ;
    aplo-ont:hasName "Self Explanation"^^xsd:string ;
    aplo-ont:servesPedagogicalObjective aplo-r:pedagogicalObjective.Externalize%20Reasoning .

aplo-r:pedagogicalObjective.Externalize%20Reasoning a aplo-ont:PedagogicalObjective ;
    aplo-ont:hasDescription "Strengthen understanding by requiring learners to state why a step or claim is valid"^^xsd:string ;
    aplo-ont:hasName "Externalize Reasoning"^^xsd:string .

